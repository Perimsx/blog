---
import { SITE } from "@/config";

export interface Props {
  type: "BlogPosting" | "Person" | "WebSite";
  data: any;
}

const { type, data } = Astro.props;

const siteUrl = SITE.website;
const siteName = SITE.title;
const siteAuthor = SITE.author;
const siteDesc = SITE.desc;
const siteOgImage = `${siteUrl}og-image.jpg`;
const readingMinutes =
  typeof data.readingTime === "string"
    ? Number.parseInt(data.readingTime, 10)
    : undefined;

let structuredData = {};

if (type === "BlogPosting") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: data.title,
    description: data.description,
    author: {
      "@type": "Person",
      name: data.author || siteAuthor,
      url: `${siteUrl}about`,
    },
    datePublished: data.pubDatetime.toISOString(),
    dateModified: data.modDatetime?.toISOString() || data.pubDatetime.toISOString(),
    publisher: {
      "@type": "Organization",
      name: siteName,
      url: siteUrl,
      logo: {
        "@type": "ImageObject",
        url: siteOgImage,
      },
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": data.url,
    },
    image: data.coverImage || data.ogImage || data.heroImage || siteOgImage,
    articleSection: data.tags?.[0] || "Technology",
    keywords: data.tags?.join(", ") || "",
    wordCount: data.wordCount,
    ...(readingMinutes ? { timeRequired: `PT${readingMinutes}M` } : {}),
    isPartOf: {
      "@type": "WebSite",
      name: siteName,
      url: siteUrl,
    },
    inLanguage: SITE.lang || "zh-CN",
  };
} else if (type === "Person") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: siteAuthor,
    url: siteUrl,
    image: siteOgImage,
    sameAs: [
      "https://github.com/Perimsx",
      "https://space.bilibili.com/9655855",
    ],
    jobTitle: "信息安全学生 / Web 开发爱好者",
    description: siteDesc,
  };
} else if (type === "WebSite") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteName,
    url: siteUrl,
    description: siteDesc,
    inLanguage: SITE.lang || "zh-CN",
    author: {
      "@type": "Person",
      name: siteAuthor,
    },
    potentialAction: {
      "@type": "SearchAction",
      target: `${siteUrl}search?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  };
}
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
