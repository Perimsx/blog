---
import type { CollectionEntry } from "astro:content";
import AdaptiveImage from "@/components/AdaptiveImage.astro";
import { getPath } from "@/utils/getPath";
import { calculateReadingTime } from "@/utils/readingTime";
import { slugifyStr } from "@/utils/slugify";
import Datetime from "./Datetime.astro";

export interface Props extends CollectionEntry<"blog"> {
  variant?: "h2" | "h3";
  showImage?: boolean;
}

const { variant = "h2", data, id, filePath, body, showImage = true } = Astro.props;

const { title, description, pubDatetime, modDatetime, timezone, coverImage, heroImage } = data;
const readingTime = calculateReadingTime(body ?? "");
const articleImage = coverImage ?? heroImage;

const headerProps = {
  style: { viewTransitionName: slugifyStr(title) },
  class: "text-base font-medium decoration-dashed hover:underline sm:text-lg",
};
---

<li class="my-5 sm:my-6">
  <div>
    <a
      href={getPath(id, filePath)}
      class="inline-block text-base font-medium text-accent decoration-dashed underline-offset-4 focus-visible:no-underline focus-visible:underline-offset-0 sm:text-lg"
    >
      {
        variant === "h2" ? (
          <h2 {...headerProps}>{title}</h2>
        ) : (
          <h3 {...headerProps}>{title}</h3>
        )
      }
    </a>
    <div class="mb-2.5 flex items-center gap-2.5 sm:mb-3 sm:gap-3">
      <Datetime {pubDatetime} {modDatetime} {timezone} />
      <span class="text-sm italic opacity-80">• {readingTime}</span>
    </div>
    <div class="flex items-start gap-3 sm:gap-4">
      {showImage && articleImage && (
        <a 
          href={getPath(id, filePath)}
          class="flex-shrink-0 hidden sm:block group"
        >
          <AdaptiveImage
            src={articleImage}
            alt={title}
            width={140}
            height={79}
            class="rounded shadow-sm transition-all duration-200 group-hover:shadow-md group-hover:scale-105 object-cover"
            format="webp"
            quality={80}
            loading="lazy"
            densities={[1, 2]}
          />
        </a>
      )}
      <p class="flex-1 text-[0.95rem] leading-7 opacity-80 sm:text-base sm:leading-8">{description}</p>
    </div>
  </div>
</li>
