---
import { Image } from "astro:assets";

export interface Props {
  src: string | ImageMetadata;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  loading?: "lazy" | "eager";
  format?: "avif" | "png" | "webp";
  quality?: number;
  densities?: number[];
}

const {
  src,
  alt,
  class: className,
  width,
  height,
  loading = "lazy",
  format,
  quality,
  densities,
} = Astro.props;
---

{
  typeof src === "string" ? (
    <img src={src} alt={alt} class={className} width={width} height={height} loading={loading} />
  ) : (
    <Image
      src={src}
      alt={alt}
      class={className}
      width={width}
      height={height}
      loading={loading}
      format={format}
      quality={quality}
      densities={densities}
    />
  )
}
