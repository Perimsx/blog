---
import Hr from "./Hr.astro";
import Socials from "./Socials.astro";

export interface Props {
  noMarginTop?: boolean;
}

const { noMarginTop = false } = Astro.props;
---

<footer class:list={["w-full", { "mt-auto": !noMarginTop }]}>
  <Hr noPadding />
  <div
    class="flex flex-col items-center justify-between py-3 sm:flex-row-reverse sm:py-4"
  >
    <Socials centered />
    <div class="my-2 flex flex-col items-center whitespace-nowrap sm:items-start text-sm">
      <a href="https://github.com/Perimsx/blog" target="_blank" rel="noopener noreferrer" class="hover:text-accent">
        CC BY 4.0 · Code MIT
      </a>
      <div class="flex flex-col sm:flex-row items-center sm:gap-3 text-xs opacity-70 mt-2 sm:mt-1">
        <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer" class="hover:text-accent">
          鄂ICP备2025157857号
        </a>
        <a href="http://www.beian.gov.cn/portal/registerSystemInfo?recordcode=42018502008592" target="_blank" rel="noopener noreferrer" class="hover:text-accent flex items-center gap-1 mt-1 sm:mt-0">
          <img src="https://img.alicdn.com/tfs/TB1..50QpXXXXX7XpXXXXXXXXXX-20-20.png" alt="公安备案图标" class="w-3.5 h-3.5" />
          鄂公网安备42018502008592号
        </a>
      </div>
    </div>
  </div>
</footer>
