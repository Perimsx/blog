---
// src/components/TableOfContents.astro
export interface Props {
  headings: { depth: number; slug: string; text: string }[];
  hideTitle?: boolean;
}

const { headings, hideTitle = false } = Astro.props;
---

<nav class="toc-container">
  {!hideTitle && <h2 class="text-[0.9rem] font-semibold mb-2 text-foreground/90">目录</h2>}
  <div class={`toc-scroll-area overflow-y-auto ${hideTitle ? 'max-h-[72vh] pr-4' : 'max-h-[40vh]'}`}>
    <ul class="relative border-l border-foreground/10 flex flex-col gap-1 text-[0.8rem] pb-24">
      {
        headings.map((heading) => (
          <li class={`toc-item ${heading.depth === 3 ? "ml-3" : ""}`}>
            <a
              href={`#${heading.slug}`}
              class="block pl-3 py-[2px] text-foreground/60 text-[0.8rem] hover:text-accent transition-all duration-300 toc-link truncate transform origin-left"
              data-slug={heading.slug}
            >
              {heading.text}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  // 页面加载完成后初始化滚动监听
  function initToc() {
    const observer = new IntersectionObserver(
      (entries) => {
        // 遍历所有观察的标题元素
        entries.forEach((entry) => {
          const id = entry.target.getAttribute("id");
          const link = document.querySelector(`.toc-link[data-slug="${id}"]`);
          
          if (!link) return;

          if (entry.isIntersecting) {
            // 当标题进入视口时，移除其他链接的高亮，给当前链接加上高亮类
            document.querySelectorAll(".toc-link").forEach((l) => {
              l.classList.remove("text-accent", "font-medium", "border-l-2", "border-accent", "whitespace-normal", "scale-105", "text-[0.85rem]");
              l.classList.add("text-foreground/60", "truncate", "text-[0.8rem]");
              // 如果你想让左侧有线条高亮效果，可以在移除/添加时操作 border
              l.parentElement?.classList.remove("border-l-2", "border-accent", "-ml-[1px]");
            });

            link.classList.remove("text-foreground/60", "truncate", "text-[0.8rem]");
            link.classList.add("text-accent", "font-medium", "whitespace-normal", "scale-105", "text-[0.85rem]");
            // 给当前高亮项的父元素(li)加上左侧高亮边框
            link.parentElement?.classList.add("border-l-2", "border-accent", "-ml-[1px]");

            // 自动滚动侧边栏使得激活项尽可能靠顶部展示
            const scrollArea = link.closest('.toc-scroll-area');
            if (scrollArea) {
              const offsetTop = link.parentElement?.offsetTop || 0;
              scrollArea.scrollTo({
                top: offsetTop > 20 ? offsetTop - 20 : 0,
                behavior: 'smooth'
              });
            }
          }
        });
      },
      {
        // 核心参数：视口判定区域。当标题滚动到视口顶部往下 10% 到 20% 的区间时触发
        rootMargin: "-10% 0px -80% 0px",
      }
    );

    // 获取文章中所有带 id 的标题，并交给 observer 观察
    const article = document.getElementById("article");
    if (article) {
      const headings = article.querySelectorAll("h2, h3, h4");
      headings.forEach((heading) => observer.observe(heading));
    }
  }

  // 兼容 Astro 的 View Transitions
  document.addEventListener("astro:page-load", initToc);
  initToc();
</script>

<style>
  /* 隐藏容器的滚动条，但保留滚动功能 */
  .toc-scroll-area::-webkit-scrollbar {
    display: none;
  }
  .toc-scroll-area {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }
</style>
