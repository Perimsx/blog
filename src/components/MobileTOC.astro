---
import TableOfContents from "@/components/TableOfContents";

export interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
---

<div class="xl:hidden">
  <!-- FAB -->
  <button
    id="mobile-toc-fab"
    class="fixed layout-floating-anchor z-40 p-3.5 bg-background shadow-xl border border-border rounded-full text-foreground hover:text-accent focus:ring-4 ring-accent/20 transition-all hover:scale-[1.03] active:scale-95 flex items-center justify-center cursor-pointer"
    aria-label="打开目录"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="8" x2="21" y1="6" y2="6"/>
      <line x1="8" x2="21" y1="12" y2="12"/>
      <line x1="8" x2="21" y1="18" y2="18"/>
      <line x1="3" x2="3.01" y1="6" y2="6"/>
      <line x1="3" x2="3.01" y1="12" y2="12"/>
      <line x1="3" x2="3.01" y1="18" y2="18"/>
    </svg>
  </button>

  <!-- Overlay -->
  <div
    id="mobile-toc-overlay"
    class="fixed inset-0 z-[60] bg-background/50 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-400 ease-out"
  ></div>

  <!-- Drawer -->
  <div
    id="mobile-toc-drawer"
    class="fixed bottom-0 left-0 right-0 z-[70] bg-background border-t border-border/60 rounded-t-3xl shadow-[0_-10px_40px_-10px_rgba(0,0,0,0.1)] transform translate-y-full transition-transform duration-400 ease-[cubic-bezier(0.32,0.72,0,1)] max-h-[85vh] flex flex-col pointer-events-none"
  >
    <!-- Handle -->
    <div class="absolute left-1/2 -translate-x-1/2 top-3.5 w-12 h-1.5 bg-muted rounded-full"></div>

    <!-- Drawer Header -->
    <div class="flex items-center justify-between px-6 pt-9 pb-4 border-b border-border/40">
      <h2 class="text-lg font-bold text-foreground">文章目录</h2>
      <button
        id="mobile-toc-close"
        class="p-1.5 -mr-1.5 bg-muted/40 rounded-full text-foreground/70 hover:text-accent hover:bg-accent/10 transition-colors"
        aria-label="关闭"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
      </button>
    </div>

    <!-- Drawer Content -->
    <div class="px-4 py-4 overflow-y-auto w-full custom-scrollbar-mobile">
      <TableOfContents headings={headings} hideTitle={true} client:load />
    </div>
  </div>
</div>

<script>
  function initMobileTOC() {
    const fab = document.getElementById("mobile-toc-fab");
    const overlay = document.getElementById("mobile-toc-overlay");
    const drawer = document.getElementById("mobile-toc-drawer");
    const closeBtn = document.getElementById("mobile-toc-close");

    if (!fab || !overlay || !drawer || !closeBtn) return;

    let isOpen = false;

    function toggleDrawer(e?: Event) {
      if (e) {
        e.preventDefault();
        e.stopPropagation();
      }

      isOpen = !isOpen;
      
      if (isOpen) {
        overlay!.classList.remove("opacity-0", "pointer-events-none");
        overlay!.classList.add("opacity-100", "pointer-events-auto");
        
        drawer!.classList.remove("translate-y-full", "pointer-events-none");
        drawer!.classList.add("translate-y-0", "pointer-events-auto");
        
        // Prevent background scroll
        document.body.style.overflow = "hidden";
      } else {
        overlay!.classList.add("opacity-0", "pointer-events-none");
        overlay!.classList.remove("opacity-100", "pointer-events-auto");
        
        drawer!.classList.add("translate-y-full", "pointer-events-none");
        drawer!.classList.remove("translate-y-0", "pointer-events-auto");
        
        // Restore background scroll
        document.body.style.overflow = "";
      }
    }

    // Clean up old listeners before attaching to avoid multiple calls under View Transitions
    const newFab = fab.cloneNode(true);
    fab.parentNode?.replaceChild(newFab, fab);
    const newClose = closeBtn.cloneNode(true);
    closeBtn.parentNode?.replaceChild(newClose, closeBtn);
    const newOverlay = overlay.cloneNode(true);
    overlay.parentNode?.replaceChild(newOverlay, overlay);

    newFab.addEventListener("click", toggleDrawer);
    newClose.addEventListener("click", toggleDrawer);
    newOverlay.addEventListener("click", toggleDrawer);

    // Auto-close on link click
    const links = drawer.querySelectorAll("a.toc-link");
    links.forEach(link => {
      link.addEventListener("click", () => {
        if (isOpen) toggleDrawer();
      });
    });
  }

  document.addEventListener("astro:page-load", initMobileTOC);
  initMobileTOC();
</script>

<style>
  .custom-scrollbar-mobile::-webkit-scrollbar {
    display: none;
  }
  .custom-scrollbar-mobile {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }
</style>
