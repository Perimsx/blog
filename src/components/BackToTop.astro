---
<button
  id="back-to-top"
  class="fixed right-4 bottom-5 z-50 opacity-0 translate-y-4 pointer-events-none transition-all duration-500 group"
  aria-label="Back to Top"
>
  <!-- Progress ring container -->
  <div class="relative flex size-12 items-center justify-center">
    <!-- Background ring -->
    <svg
      class="absolute inset-0 size-12 -rotate-90"
      viewBox="0 0 48 48"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <circle
        cx="24"
        cy="24"
        r="20"
        stroke="currentColor"
        stroke-width="3"
        class="text-foreground/10"
      />
      <!-- Progress ring -->
      <circle
        id="scroll-progress-ring"
        cx="24"
        cy="24"
        r="20"
        stroke="currentColor"
        stroke-width="3"
        stroke-linecap="round"
        stroke-dasharray="125.66"
        stroke-dashoffset="125.66"
        class="text-accent transition-[stroke-dashoffset] duration-100"
      />
    </svg>

    <!-- Arrow icon -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-foreground/60 group-hover:text-accent transition-all duration-300 group-hover:-translate-y-0.5"
    >
      <path d="M12 19V5M5 12l7-7 7 7" />
    </svg>
  </div>

  <!-- Label -->
  <span class="absolute -top-7 left-1/2 -translate-x-1/2 text-xs font-medium text-foreground/40 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
    Top
  </span>
</button>

<script>
  function initBackToTop() {
    window.__backToTopCleanup?.();

    const backToTopBtn = document.querySelector("#back-to-top") as HTMLButtonElement;
    const progressRing = document.querySelector(
      "#scroll-progress-ring",
    ) as SVGCircleElement;

    if (!backToTopBtn || !progressRing) return;

    const circumference = 125.66; // 2 * PI * 20

    const updateProgress = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? scrollTop / docHeight : 0;
      const offset = circumference - progress * circumference;
      progressRing.style.strokeDashoffset = String(offset);

      // Show/hide button
      if (scrollTop > 300) {
        backToTopBtn.classList.remove("opacity-0", "translate-y-4", "pointer-events-none");
        backToTopBtn.classList.add("opacity-100", "translate-y-0", "pointer-events-auto");
      } else {
        backToTopBtn.classList.add("opacity-0", "translate-y-4", "pointer-events-none");
        backToTopBtn.classList.remove("opacity-100", "translate-y-0", "pointer-events-auto");
      }
    };

    const handleClick = () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    };

    window.addEventListener("scroll", updateProgress, { passive: true });
    backToTopBtn.addEventListener("click", handleClick);

    updateProgress();

    window.__backToTopCleanup = () => {
      window.removeEventListener("scroll", updateProgress);
      backToTopBtn.removeEventListener("click", handleClick);
    };
  }

  initBackToTop();
  document.addEventListener("astro:after-swap", initBackToTop);
</script>

<style is:global>
  #back-to-top {
    right: max(1rem, calc((100vw - 48rem) / 2 - 3.75rem));
    bottom: 1.25rem;
  }

  @media (min-width: 640px) {
    #back-to-top {
      top: 6.75rem;
      right: max(1.5rem, calc((100vw - 48rem) / 2 - 3.5rem));
      bottom: auto;
    }
  }
</style>
