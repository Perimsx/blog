---
---
<button
  id="back-to-top"
  class="layout-floating-anchor fixed z-50 opacity-0 translate-y-4 pointer-events-none transition-all duration-500 group"
  aria-label="Back to Top"
>
  <!-- Progress ring container -->
  <div class="relative flex size-12 items-center justify-center">
    <!-- Background ring -->
    <svg
      class="absolute inset-0 size-12 -rotate-90"
      viewBox="0 0 48 48"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <circle
        cx="24"
        cy="24"
        r="20"
        stroke="currentColor"
        stroke-width="3"
        class="text-foreground/10"
      />
      <!-- Progress ring -->
      <circle
        id="scroll-progress-ring"
        cx="24"
        cy="24"
        r="20"
        stroke="currentColor"
        stroke-width="3"
        stroke-linecap="round"
        stroke-dasharray="125.66"
        stroke-dashoffset="125.66"
        class="text-accent transition-[stroke-dashoffset] duration-100"
      />
    </svg>

    <!-- Arrow icon -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-foreground/60 group-hover:text-accent transition-all duration-300 group-hover:-translate-y-0.5"
    >
      <path d="M12 19V5M5 12l7-7 7 7" />
    </svg>
  </div>

  <!-- Label -->
  <span class="absolute -top-7 left-1/2 -translate-x-1/2 text-xs font-medium text-foreground/40 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
    Top
  </span>
</button>

<script>
  import { initBackToTop } from "@/scripts/backToTop";

  initBackToTop();
</script>

<style is:global>
  #back-to-top {
    right: var(--layout-floating-mobile-right);
    bottom: var(--layout-floating-mobile-bottom);
  }

  @media (min-width: 640px) {
    #back-to-top {
      top: auto;
      right: var(--layout-floating-right);
      bottom: var(--layout-floating-bottom);
    }
  }
</style>
