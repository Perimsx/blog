---
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconX from "@/assets/icons/IconX.svg";
import { SITE } from "@/config";
import ContactModal from "./ContactModal.astro";
import Hr from "./Hr.astro";
import SearchModal from "./SearchModal.astro";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath = pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter((p) => p.trim());
  const pathArray = path.split("/").filter((p) => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<header>
  <ContactModal />
  <SearchModal />
  <a
    id="skip-to-content"
    href="#main-content"
    class="absolute -top-full left-16 z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
  >
    Skip to content
  </a>
  <div
    id="nav-container"
    class="layout-frame flex flex-col items-center justify-between sm:flex-row"
  >
    <div
      id="top-nav-wrap"
      class="relative flex w-full items-baseline justify-between bg-background py-3 sm:items-center sm:py-6"
    >
      <a
        href="/"
        class="font-logo absolute py-1 text-2xl leading-7 whitespace-nowrap sm:static"
      >
        {SITE.title}
      </a>
      <nav
        id="nav-menu"
        class="flex w-full flex-col items-center sm:ml-2 sm:flex-row sm:justify-end sm:space-x-4 sm:py-0"
      >
        <button
          id="menu-btn"
          class="focus-outline self-end p-2 sm:hidden"
          aria-label="Open Menu"
          aria-expanded="false"
          aria-controls="menu-items"
        >
          <IconX id="close-icon" class="hidden" />
          <IconMenuDeep id="menu-icon" />
        </button>
        <ul
          id="menu-items"
          class:list={[
            "mt-2.5 grid w-40 grid-cols-2 place-content-center gap-1.5",
            "[&>li>a]:block [&>li>a]:px-4 [&>li>a]:py-2 [&>li>a]:text-center [&>li>a]:font-medium [&>li>a]:hover:text-accent sm:[&>li>a]:px-2 sm:[&>li>a]:py-1",
            "hidden",
            "sm:mt-0 sm:ml-0 sm:flex sm:w-auto sm:gap-x-5 sm:gap-y-0",
          ]}
        >
          <li class="col-span-2">
            <a href="/posts" class:list={{ "active-nav": isActive("/posts") }}>
              Posts
            </a>
          </li>
          <li class="col-span-2">
            <a href="/tags" class:list={{ "active-nav": isActive("/tags") }}>
              Tags
            </a>
          </li>
          <li class="col-span-2">
            <a href="/about" class:list={{ "active-nav": isActive("/about") }}>
              About
            </a>
          </li>
          <li class="col-span-2 flex items-center justify-center gap-3 py-1.5 sm:gap-x-5 sm:py-0">
            <!-- 联系站长 -->
            <button
              id="contact-btn"
              class="focus-outline flex size-10 cursor-pointer items-center justify-center p-2.5 sm:size-8 sm:p-1 hover:brightness-110 active:scale-95 transition-all"
              title="联系站长"
              aria-label="联系站长"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="2" y="4" width="20" height="16" rx="2" fill="#e4393c" />
                <path d="M22 4l-10 8L2 4" stroke="white" stroke-width="2" />
                <path d="M2 20l8-8m4 0l8 8" stroke="white" stroke-width="1.5" opacity="0.4" />
              </svg>
            </button>

            <!-- 搜索 -->
            <button
              id="search-btn"
              class="focus-outline flex cursor-pointer p-2.5 sm:p-1"
              aria-label="搜索"
              title="搜索"
              type="button"
            >
              <IconSearch />
              <span class="sr-only">搜索</span>
            </button>

            <!-- 主题切换 -->
            {
              SITE.lightAndDarkMode && (
                <button
                  id="theme-btn"
                  class="theme-toggle-btn focus-outline relative size-10 p-3 sm:size-8 hover:[&>svg]:stroke-accent"
                  title="Toggles light & dark"
                  aria-label="auto"
                  aria-live="polite"
                >
                  <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                  <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                </button>
              )
            }
          </li>
        </ul>
      </nav>
    </div>
  </div>
  <Hr />
</header>

<script>
  import { initHeaderInteractions } from "@/scripts/header";

  initHeaderInteractions();
</script>
