---
interface Props {
  code?: string;
  title: string;
  description: string;
  variant?: "error" | "warning" | "info";
  compact?: boolean;
}

const {
  code,
  title,
  description,
  variant = "error",
  compact = false,
} = Astro.props;
---

<div class:list={["status-panel", `status-panel--${variant}`, compact && "status-panel--compact"]}>
  <div class="status-panel__eyebrow">
    {code && <span class="status-panel__code">{code}</span>}
    <span class="status-panel__pill">{variant === "error" ? "异常状态" : variant === "warning" ? "注意" : "提示"}</span>
  </div>
  <h1 class="status-panel__title">{title}</h1>
  <p class="status-panel__desc">{description}</p>
  <div class="status-panel__actions">
    <slot />
  </div>
</div>
