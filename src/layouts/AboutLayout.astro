---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import Layout from "./Layout.astro";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`} description={frontmatter.description}>
  <Header />
  <main id="main-content" class="ui-page mx-auto w-full max-w-3xl px-4 pb-6 sm:pb-10">
    <section id="about" class="prose mt-4 mb-14 w-full max-w-none prose-img:border-0 sm:mt-6 sm:mb-20">
      <h1 class="about-page-title">{frontmatter.title}</h1>
      <slot />
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  #about {
    width: 100%;
    max-width: none;
    margin-inline: 0;
    padding-inline: 0;
    overflow-x: clip;
  }

  #about .about-hero {
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.6rem;
  }

  #about > h1.about-page-title {
    margin: 0 0 1.1rem;
    font-size: clamp(1.65rem, 7vw, 2rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  #about .about-hero-media {
    width: min(100%, 17.5rem);
    margin-inline: auto;
  }

  #about .about-hero-media img {
    margin: 0;
    border-radius: 1rem;
  }

  #about .about-hero-copy {
    width: 100%;
  }

  #about .about-hero-copy > h2 {
    margin-top: 0;
    margin-bottom: 0.55rem;
    font-size: clamp(1.36rem, 5.8vw, 1.72rem);
    line-height: 1.22;
    letter-spacing: -0.02em;
  }

  #about .about-hero-copy > p {
    margin: 0;
    max-width: 34rem;
    font-size: 0.92rem;
    line-height: 1.72;
  }

  #about .about-block + .about-block {
    margin-top: 1.7rem;
  }

  #about .about-block > h2 {
    margin: 0 0 0.65rem;
    font-size: clamp(1.2rem, 5.6vw, 1.52rem);
    line-height: 1.28;
    letter-spacing: -0.02em;
  }

  #about .about-block > p,
  #about .about-note {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.72;
  }

  #about .about-list {
    margin: 0;
    padding-left: 0.95rem;
  }

  #about .about-list li {
    margin-block: 0.42rem;
    line-height: 1.65;
  }

  #about .about-links {
    margin-top: 0.55rem;
  }

  #about .about-note {
    margin-top: 0.65rem;
  }

  #about :where(a) {
    word-break: break-word;
  }

  @media (min-width: 641px) {
    #about > h1.about-page-title {
      margin-bottom: 1.45rem;
      font-size: 2.15rem;
    }

    #about .about-hero {
      gap: 1.5rem;
      margin-bottom: 1.9rem;
    }

    #about .about-hero-media {
      width: min(100%, 18.5rem);
      margin-inline: 0;
    }

    #about .about-hero-copy > h2 {
      margin-bottom: 0.65rem;
      font-size: clamp(1.65rem, 3vw, 1.95rem);
    }

    #about .about-hero-copy > p {
      font-size: 0.96rem;
      line-height: 1.78;
    }

    #about .about-block + .about-block {
      margin-top: 2rem;
    }

    #about .about-block > h2 {
      margin-bottom: 0.8rem;
      font-size: clamp(1.42rem, 2.8vw, 1.68rem);
    }

    #about .about-list {
      padding-left: 1.05rem;
    }

    #about .about-list li {
      margin-block: 0.5rem;
      line-height: 1.7;
    }

    #about .about-block > p,
    #about .about-note {
      font-size: 0.95rem;
      line-height: 1.76;
    }
  }

  @media (max-width: 640px) {
    #about {
      margin-bottom: 4.5rem;
    }

    #about .about-block > h2 {
      text-wrap: balance;
    }
  }
</style>
