---
import { type CollectionEntry, render } from "astro:content";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import AdaptiveImage from "@/components/AdaptiveImage.astro";
import BackButton from "@/components/BackButton.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Callout from "@/components/mdx/Callout.astro";
import Card from "@/components/mdx/Card.astro";
import Grid from "@/components/mdx/Grid.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import StructuredData from "@/components/StructuredData.astro";
import Tag from "@/components/Tag.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
import { getPath } from "@/utils/getPath";
import { calculateReadingTime } from "@/utils/readingTime";
import { slugifyStr } from "@/utils/slugify";

export interface Props {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
}

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  coverImage,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
  heroImage,
} = post.data;

const { Content } = await render(post);
const readingTime = calculateReadingTime(post.body ?? "");

let ogImageUrl: string | undefined;
const articleImage = coverImage ?? heroImage;
const postPath = getPath(post.id, post.filePath, post.data.url, true);

// Determine OG image source
if (typeof coverImage === "string") {
  ogImageUrl = coverImage; // Shared cover image (remote URL)
} else if (coverImage?.src) {
  ogImageUrl = coverImage.src; // Shared local cover asset
} else if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote|local ogImage
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${postPath}/index.png`;
}

// Resolve OG image URL (or fallback to SITE.ogImage / default `og.png`)
const ogImage = ogImageUrl ? new URL(ogImageUrl, Astro.url.origin).href : undefined;

// Generate the canonical URL
const computedCanonicalURL =
  canonicalURL ||
  (Astro.site ? new URL(postPath, Astro.site).href : new URL(postPath, Astro.url.origin).href);

const layoutProps = {
  title: title,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL: computedCanonicalURL,
  ogImage,
  scrollSmooth: true,
  disableAutoStructuredData: true,
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map((entry) => ({
  path: getPath(entry.id, entry.filePath, entry.data.url, true),
  key: entry.id,
  title: entry.data.title,
}));

const currentPostIndex = allPosts.findIndex((entry) => entry.key === post.id);

const prevPost = currentPostIndex > 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex >= 0 && currentPostIndex < allPosts.length - 1
    ? allPosts[currentPostIndex + 1]
    : null;
const wordCount = (post.body ?? "").split(/\s+/).length;

const mdxComponents = {
  Grid,
  Card,
  Callout,
};
---

<Layout {...layoutProps}>
  <StructuredData 
    type="BlogPosting" 
    data={{
      title,
      description,
      author,
      pubDatetime,
      modDatetime,
      url: computedCanonicalURL,
      coverImage: ogImage,
      ogImage,
      tags,
      wordCount,
      readingTime
    }} 
  />
  <Header />
  <BackButton />
  <main
    id="main-content"
    class:list={[
      "layout-frame w-full pb-12",
      { "mt-8": !SITE.showBackButton },
    ]}
    data-pagefind-body
  >
    <h1
      transition:name={slugifyStr(title)}
      title={title}
      class="block w-full text-[1.78rem] leading-[1.16] font-semibold text-accent sm:text-[1.98rem] lg:text-[1.9rem] lg:truncate"
    >
      {title}
    </h1>
    <div class="mt-1.5 mb-5 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
        {
          readingTime && (
            <>
              <span class="text-foreground/30">•</span>
              <span class="text-[0.95rem] italic text-foreground/60">{readingTime}</span>
            </>
          )
        }
      </div>
      <EditPost class="max-sm:hidden" {hideEditPost} {post} />
    </div>
    <article id="article" class="article-detail mx-auto prose mt-8 max-w-3xl">
      {
        articleImage && (
          <AdaptiveImage
            src={articleImage}
            alt={title}
            class="mb-6 aspect-video w-full rounded-md object-cover"
            loading="lazy"
          />
        )
      }
      <Content components={mdxComponents} />
    </article>



    <div class="flex flex-wrap items-center justify-between gap-4 mt-4 mb-4 sm:my-6">
      <ul class="flex flex-wrap gap-x-4 gap-y-2">
        {tags.map((tag) => <Tag tag={slugifyStr(tag)} tagName={tag} />)}
      </ul>
      <ShareLinks />
    </div>

    <!-- Mobile only: EditPost below tags -->
    <EditPost class="sm:hidden" {hideEditPost} {post} />

    <hr class="my-6 border-dashed" />

    <!-- Previous/Next Post Buttons -->
    <div 
      data-pagefind-ignore 
      class="flex flex-col sm:flex-row justify-between gap-6"
      data-prev-url={prevPost?.path ?? ""}
      data-next-url={nextPost?.path ?? ""}
    >
      {
        prevPost && (
          <a
            href={prevPost.path}
            class="flex gap-2 hover:opacity-75 items-start"
            id="prev-post-link"
          >
            <IconChevronLeft class="inline-block flex-shrink-0 mt-0.5" />
            <div class="min-w-0">
              <span class="block text-sm text-foreground/70">上一篇</span>
              <div class="text-accent/85">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={nextPost.path}
            class="flex gap-2 hover:opacity-75 items-start justify-end text-right ml-auto"
            id="next-post-link"
          >
            <div class="min-w-0">
              <span class="block text-sm text-foreground/70">下一篇</span>
              <div class="text-accent/85">{nextPost.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-shrink-0 mt-0.5" />
          </a>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import { initPostDetailsPage } from "@/scripts/postDetails";

  initPostDetailsPage();
  document.addEventListener("astro:page-load", initPostDetailsPage);
</script>

<style>
  .youtube-embed-container {
    margin: 2rem 0;
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    height: 0;
    overflow: hidden;
  }

  .youtube-embed-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
