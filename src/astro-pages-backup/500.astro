---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import LinkButton from "@/components/LinkButton.astro";
import StatusPanel from "@/components/StatusPanel.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
---

<Layout title={`服务异常 | ${SITE.title}`} description="页面暂时无法打开，请稍后重试。">
  <Header />

  <main
    id="main-content"
    class="ui-page mx-auto flex max-w-3xl flex-1 items-center justify-center px-4"
  >
    <StatusPanel
      code="500"
      title="服务暂时不可用"
      description="页面暂时无法打开，可能是服务波动或资源尚未准备完成。稍后刷新再试即可。"
    >
      <LinkButton
        href="/"
        class="text-base underline decoration-dashed underline-offset-8 sm:text-lg"
      >
        返回首页
      </LinkButton>
    </StatusPanel>
  </main>

  <Footer />
</Layout>
