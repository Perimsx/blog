---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
import Main from "@/layouts/Main.astro";
---

<Layout title={`Contact | ${SITE.title}`} description="联系站长 Perimsx">
  <Header />
  <Main pageTitle="Contact" pageDesc="Send me a message ...">
    <div class="space-y-6">
      <p class="text-[0.95rem] leading-7 text-foreground/80 sm:text-base">
        有任何问题或建议，欢迎留言。也可以通过以下方式联系我：
      </p>

      <div class="flex flex-wrap gap-3 sm:gap-4">
        <a
          href="mailto:1722288011@qq.com"
          class="inline-flex w-full items-center justify-center gap-2 rounded bg-accent px-4 py-2.5 text-[0.95rem] text-white transition-opacity hover:opacity-90 sm:w-auto sm:text-base"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect width="20" height="16" x="2" y="4" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
          发送邮件
        </a>
        <a
          href="https://wpa.qq.com/msgrd?v=3&uin=1722288011&site=qq&menu=yes"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-full items-center justify-center gap-2 rounded bg-muted px-4 py-2.5 text-[0.95rem] text-foreground transition-colors hover:bg-accent/20 sm:w-auto sm:text-base"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.38 0 2.5 1.12 2.5 2.5 0 .65-.25 1.24-.66 1.67-.41.43-.66 1.02-.66 1.67 0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5c0-.65.25-1.24.66-1.67.41-.43.66-1.02.66-1.67 0-1.38-1.12-2.5-2.5-2.5-.83 0-1.57.41-2.01 1.03-.37.52-.59 1.15-.59 1.83 0 .68.22 1.31.59 1.83.44.62 1.18 1.03 2.01 1.03 1.38 0 2.5-1.12 2.5-2.5 0-.65-.25-1.24-.66-1.67-.41-.43-.66-1.02-.66-1.67C14.5 6.12 13.38 5 12 5z"
          />
          <path
            d="M7.88 11.67c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1zm4.12 0c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1zm4 0c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1z"
          ></path>
          </svg>
          QQ 联系
        </a>
      </div>

      <hr class="border-border" />

      <form id="contact-page-form" class="max-w-lg space-y-3.5 sm:space-y-4">
        <div>
          <label for="contact-page-name" class="mb-1 block text-[0.9rem] font-medium text-foreground sm:text-sm">
            姓名（选填）
          </label>
          <input
            type="text"
            id="contact-page-name"
            name="name"
            placeholder="你的名字"
            class="w-full rounded border border-border bg-background px-3 py-2 text-[0.95rem] text-foreground placeholder:text-foreground/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/50 sm:text-base"
          />
        </div>

        <div>
          <label for="contact-page-email" class="mb-1 block text-[0.9rem] font-medium text-foreground sm:text-sm">
            邮箱（选填）
          </label>
          <input
            type="email"
            id="contact-page-email"
            name="email"
            placeholder="方便我回复你"
            class="w-full rounded border border-border bg-background px-3 py-2 text-[0.95rem] text-foreground placeholder:text-foreground/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/50 sm:text-base"
          />
        </div>

        <div>
          <label for="contact-page-qq" class="mb-1 block text-[0.9rem] font-medium text-foreground sm:text-sm">
            QQ（选填，推荐）
          </label>
          <input
            type="text"
            id="contact-page-qq"
            name="qq"
            placeholder="方便的话可以留下 QQ 号"
            class="w-full rounded border border-border bg-background px-3 py-2 text-[0.95rem] text-foreground placeholder:text-foreground/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/50 sm:text-base"
          />
        </div>

        <div>
          <label for="contact-page-message" class="mb-1 block text-[0.9rem] font-medium text-foreground sm:text-sm">
            留言内容 <span class="text-accent">*</span>
          </label>
          <textarea
            id="contact-page-message"
            name="message"
            rows="5"
            placeholder="想说点什么..."
            required
            class="w-full resize-y rounded border border-border bg-background px-3 py-2 text-[0.95rem] text-foreground placeholder:text-foreground/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/50 sm:text-base"
          ></textarea>
        </div>

        <div id="contact-page-status" class="hidden text-sm"></div>

        <button
          type="submit"
          id="contact-page-submit"
          class="rounded bg-accent px-5 py-2.5 text-[0.95rem] font-medium text-white transition-opacity hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-50 sm:px-6 sm:py-2 sm:text-base"
        >
          发送留言
        </button>
      </form>
    </div>
  </Main>
  <Footer />
</Layout>

<script>
  const form = document.getElementById("contact-page-form") as HTMLFormElement | null;
  const status = document.getElementById("contact-page-status") as HTMLDivElement | null;
  const submitBtn = document.getElementById("contact-page-submit") as HTMLButtonElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!status || !submitBtn) return;

    const formData = new FormData(form);
    const data = {
      name: formData.get("name") as string,
      email: formData.get("email") as string,
      qq: formData.get("qq") as string,
      message: formData.get("message") as string,
    };

    if (!data.message?.trim()) {
      status.textContent = "请填写留言内容";
      status.className = "text-sm text-red-500";
      status.classList.remove("hidden");
      return;
    }

    if (!data.email?.trim() && !data.qq?.trim()) {
      status.textContent = "请至少留下邮箱或 QQ";
      status.className = "text-sm text-red-500";
      status.classList.remove("hidden");
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "发送中...";
    status.classList.add("hidden");

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (res.ok) {
        status.textContent = "发送成功！我会尽快回复你。";
        status.className = "text-sm text-green-500";
        status.classList.remove("hidden");
        form.reset();
      } else {
        status.textContent = result.error || "发送失败，请重试。";
        status.className = "text-sm text-red-500";
        status.classList.remove("hidden");
      }
    } catch {
      status.textContent = "网络错误，请检查网络后重试。";
      status.className = "text-sm text-red-500";
      status.classList.remove("hidden");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "发送留言";
    }
  });
</script>
