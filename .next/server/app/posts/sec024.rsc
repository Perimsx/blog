2a:["$","div",null,{"className":"flex flex-col sm:flex-row justify-between gap-6","children":[["$","$L5",null,{"href":"/posts/sec025","className":"flex gap-2 hover:opacity-75 items-start","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M15 6l-6 6l6 6"}]]}],["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"上一篇"}],["$","div",null,{"className":"text-accent/85","children":"提权技术与利用详解"}]]}]]}],["$","$L5",null,{"href":"/posts/sec023","className":"flex gap-2 hover:opacity-75 items-start justify-end text-right ml-auto","children":[["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"下一篇"}],["$","div",null,{"className":"text-accent/85","children":"信息收集与目标侦察"}]]}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M9 6l6 6l-6 6"}]]}]]}]]}]
25:[["$","blockquote",null,{"children":["\n",["$","p",null,{"children":"阅读提示\n适合对象：在做 Linux 服务攻击面学习与授权测试的读者。\n阅读前提：熟悉 SSH、FTP、Samba、Apache 等常见服务。\n核心收获：掌握常见服务的枚举、漏洞验证与防护加固思路。\n说明：漏洞是否可利用与目标版本、配置和补丁状态强相关。"}],"\n"]}],"\n",["$","p",null,{"children":"在渗透测试过程中，信息收集阶段发现的开放端口和服务就是我们的\"入口\"。Linux 服务器上常见的 SSH、FTP、Samba、Apache 等服务，如果配置不当或存在已知漏洞，往往会成为攻击者突破防线的突破口。本文将针对这四类常见服务，详细讲解每种服务的攻击面、漏洞利用方式和实战操作步骤，同时给出对应的加固建议，帮助你全面理解服务层面的安全风险。"}],"\n",["$","h2",null,{"id":"前置准备","children":["前置准备",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#前置准备","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"在开始漏洞利用之前，假设我们已经通过 Nmap 完成了目标的信息收集："}],"\n","$L2d","\n",["$","p",null,{"children":"接下来，我们逐一对每个服务进行渗透测试。"}],"\n",["$","h2",null,{"id":"ssh-攻击面端口-22","children":["SSH 攻击面（端口 22）",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#ssh-攻击面端口-22","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"SSH（Secure Shell）是 Linux 系统远程管理的核心服务。虽然 SSH 本身使用加密通信，但仍然存在多种攻击路径。"}],"\n",["$","h3",null,{"id":"1-ssh-暴力破解","children":["1. SSH 暴力破解",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#1-ssh-暴力破解","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"最常见的 SSH 攻击方式就是密码暴力破解，使用 Hydra 是最高效的选择。"}],"\n","$L2e","\n",["$","h3",null,{"id":"2-ssh-密钥泄露利用","children":["2. SSH 密钥泄露利用",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#2-ssh-密钥泄露利用","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"如果目标系统的私钥文件因为不当配置而暴露（例如通过 Web 目录或备份文件），可以直接利用。"}],"\n","$L2f","\n",["$","h3",null,{"id":"3-ssh-版本漏洞","children":["3. SSH 版本漏洞",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#3-ssh-版本漏洞","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"某些旧版本的 OpenSSH 存在已知漏洞："}],"\n","$L30","\n",["$","h3",null,{"id":"ssh-加固建议","children":["SSH 加固建议",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#ssh-加固建议","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L31","\n",["$","h2",null,{"id":"ftp-攻击面端口-21","children":["FTP 攻击面（端口 21）",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#ftp-攻击面端口-21","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"FTP 协议本身是明文传输的，存在大量安全隐患。"}],"\n",["$","h3",null,{"id":"1-ftp-匿名登录","children":["1. FTP 匿名登录",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#1-ftp-匿名登录","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"许多 FTP 服务默认允许匿名登录，可能泄露敏感文件。"}],"\n","$L32","\n",["$","h3",null,{"id":"2-ftp-暴力破解","children":["2. FTP 暴力破解",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#2-ftp-暴力破解","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L33","\n",["$","h3",null,{"id":"3-proftpd-漏洞利用","children":["3. ProFTPd 漏洞利用",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#3-proftpd-漏洞利用","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"ProFTPd 历史上存在多个严重漏洞："}],"\n","$L34","\n",["$","h3",null,{"id":"ftp-加固建议","children":["FTP 加固建议",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#ftp-加固建议","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"如非必要，禁用 FTP 服务，改用 SFTP"}],"\n",["$","li",null,{"children":["禁用匿名登录：",["$","code",null,{"children":"anonymous_enable=NO"}]]}],"\n",["$","li",null,{"children":["启用 TLS 加密：配置 vsftpd 的 ",["$","code",null,{"children":"ssl_enable=YES"}]]}],"\n",["$","li",null,{"children":["限制用户目录：",["$","code",null,{"children":"chroot_local_user=YES"}]]}],"\n",["$","li",null,{"children":["监控 FTP 日志：",["$","code",null,{"children":"/var/log/vsftpd.log"}]]}],"\n"]}],"\n",["$","h2",null,{"id":"samba-攻击面端口-139445","children":["Samba 攻击面（端口 139/445）",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#samba-攻击面端口-139445","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"Samba 为 Linux 提供 Windows 文件共享服务，是内网渗透中的重要攻击面。"}],"\n",["$","h3",null,{"id":"1-samba-信息枚举","children":["1. Samba 信息枚举",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#1-samba-信息枚举","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L35","\n",["$","h3",null,{"id":"2-samba-空会话与共享访问","children":["2. Samba 空会话与共享访问",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#2-samba-空会话与共享访问","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L36","\n",["$","h3",null,{"id":"3-samba-漏洞利用","children":["3. Samba 漏洞利用",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#3-samba-漏洞利用","children":"$L37"}]]}],"\n","$L38","\n","$L39","\n","$L3a","\n","$L3b","\n","$L3c","\n","$L3d","\n","$L3e","\n","$L3f","\n","$L40","\n","$L41","\n","$L42","\n","$L43","\n","$L44","\n","$L45","\n","$L46","\n","$L47","\n","$L48","\n","$L49","\n","$L4a","\n","$L4b","\n","$L4c","\n","$L4d"]
