58:["$","ol",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"强密码策略"}]," — 服务账户使用 25 位以上的强密码，域管理员密码定期轮换"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"限制特权账户"}]," — 减少 Domain Admins 组成员，使用分层管理模型"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"启用 Kerberos 预认证"}]," — 确保所有账户启用 Kerberos 预认证"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"监控 Kerberoasting"}]," — 监控异常的 TGS 请求（Event ID 4769）"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"使用组管理服务账户（gMSA）"}]," — 自动轮换密码，防止 Kerberoasting"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"限制横向移动"}]," — 使用 Windows 防火墙和网络分段限制工作站间通信"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"部署 LAPS"}]," — 使用 Local Administrator Password Solution 管理本地管理员密码"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"启用 Protected Users 组"}]," — 防止 NTLM 认证和凭据缓存"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"监控 BloodHound 收集行为"}]," — 检测大量 LDAP 查询和 SMB 会话枚举"]}],"\n"]}]
