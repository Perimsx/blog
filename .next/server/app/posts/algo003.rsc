2c:["$","div",null,{"className":"flex flex-col sm:flex-row justify-between gap-6","children":[["$","$L5",null,{"href":"/posts/algo001","className":"flex gap-2 hover:opacity-75 items-start","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M15 6l-6 6l6 6"}]]}],["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"上一篇"}],["$","div",null,{"className":"text-accent/85","children":"十大排序算法详解"}]]}]]}],["$","$L5",null,{"href":"/posts/sec032","className":"flex gap-2 hover:opacity-75 items-start justify-end text-right ml-auto","children":[["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"下一篇"}],["$","div",null,{"className":"text-accent/85","children":"Windows后渗透实战"}]]}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M9 6l6 6l-6 6"}]]}]]}]]}]
25:[["$","blockquote",null,{"children":["\n",["$","p",null,{"children":"阅读提示\n适合对象：想系统梳理 BFS、DFS、最短路和最小生成树的算法学习者。\n阅读前提：理解队列、栈、优先队列和邻接表。\n核心收获：明确图论高频算法的适用边界与题型切换方式。"}],"\n"]}],"\n",["$","p",null,{"children":"图（Graph）是计算机科学中最通用、最强大的数据结构之一。社交网络中的人际关系、互联网中的网页链接、地图中的城市与公路、编译器中的函数调用关系——这些现实世界的问题都可以自然地抽象为图模型。掌握图算法，是从\"编程入门\"迈向\"算法进阶\"的关键一步。"}],"\n",["$","p",null,{"children":"本文将系统讲解图的基本概念、两种核心遍历方式（BFS 和 DFS）、三大最短路径算法（Dijkstra、Floyd-Warshall、Bellman-Ford）、两种最小生成树算法（Prim、Kruskal）以及拓扑排序。所有代码均使用 Python 编写并附有详细注释。"}],"\n",["$","h2",null,{"id":"图的基本概念","children":["图的基本概念",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#图的基本概念","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","h3",null,{"id":"有向图与无向图","children":["有向图与无向图",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#有向图与无向图","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"无向图（Undirected Graph）"}],"：边没有方向，表示双向关系。如社交网络中的\"好友关系\"。"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"有向图（Directed Graph / Digraph）"}],"：边有方向，表示单向关系。如微博中的\"关注关系\"。"]}],"\n"]}],"\n",["$","h3",null,{"id":"带权图与无权图","children":["带权图与无权图",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#带权图与无权图","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"无权图"}],"：所有边的权重相同（通常视为 1）。"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"带权图（Weighted Graph）"}],"：每条边附带一个数值（权重），表示距离、费用、时间等。"]}],"\n"]}],"\n",["$","h3",null,{"id":"图的存储方式","children":["图的存储方式",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#图的存储方式","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"邻接矩阵（Adjacency Matrix）"}],"：使用二维数组 ",["$","code",null,{"children":"graph[i][j]"}]," 存储节点 i 到节点 j 的边信息。"]}],"\n","$L2e","\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"优点：查询任意两点是否相邻为 O(1)"}],"\n",["$","li",null,{"children":"缺点：空间 O(V²)，对稀疏图浪费严重"}],"\n"]}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"邻接表（Adjacency List）"}],"：每个节点维护一个列表，存储其所有邻居及边权。"]}],"\n","$L2f","\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"优点：空间 O(V + E)，遍历邻居高效"}],"\n",["$","li",null,{"children":"缺点：查询两点是否相邻需 O(degree) 时间"}],"\n"]}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"选择原则："}]," 稀疏图（E 远小于 V²）用邻接表，稠密图（E 接近 V²）用邻接矩阵。实际工程中，邻接表是更常见的选择。"]}],"\n",["$","h2",null,{"id":"图的遍历","children":["图的遍历",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#图的遍历","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"图的遍历是几乎所有图算法的基础，分为两种经典方式：广度优先搜索（BFS）和深度优先搜索（DFS）。"}],"\n",["$","h3",null,{"id":"bfs--广度优先搜索","children":["BFS — 广度优先搜索",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#bfs--广度优先搜索","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"原理："}]," BFS 从起始节点出发，逐层向外扩展。它先访问所有距离为 1 的节点，再访问距离为 2 的节点，以此类推。BFS 使用**队列（Queue）**来维护待访问节点的顺序。"]}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"核心特性："}]," 在无权图中，BFS 找到的路径一定是最短路径。"]}],"\n","$L30","\n",["$","p",null,{"children":["$","strong",null,{"children":"应用场景："}]}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"无权图的最短路径"}],"\n",["$","li",null,{"children":"层序遍历（二叉树的层次遍历本质就是 BFS）"}],"\n",["$","li",null,{"children":"连通分量检测"}],"\n",["$","li",null,{"children":"网络爬虫的广度抓取策略"}],"\n"]}],"\n",["$","h3",null,{"id":"dfs--深度优先搜索","children":["DFS — 深度优先搜索",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#dfs--深度优先搜索","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"原理："}]," DFS 从起始节点出发，沿着一条路径尽可能深入，直到无法继续时回溯到上一个分叉点。DFS 可以使用",["$","strong",null,{"children":"递归"}],"或",["$","strong",null,{"children":"显式栈"}],"实现。"]}],"\n","$L31","\n",["$","p",null,{"children":["$","strong",null,{"children":"应用场景："}]}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"连通性判断（图是否连通）"}],"\n",["$","li",null,{"children":"环检测"}],"\n",["$","li",null,{"children":"拓扑排序"}],"\n",["$","li",null,{"children":"路径搜索与回溯算法"}],"\n",["$","li",null,{"children":"强连通分量（Tarjan 算法、Kosaraju 算法）"}],"\n"]}],"\n",["$","h3",null,{"id":"bfs-vs-dfs-对比","children":["BFS vs DFS 对比",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#bfs-vs-dfs-对比","children":["$","span",null,{"children":"#"}]}]]}],"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n",["$","table",null,{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th",null,{"children":"特性"}],["$","th",null,{"children":"BFS"}],["$","th",null,{"children":"DFS"}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"children":["$L32","$L33","$L34"]}],"$L35","$L36","$L37"]}]]}],"\n","$L38","\n","$L39","\n","$L3a","\n","$L3b","\n","$L3c","\n","$L3d","\n","$L3e","\n","$L3f","\n","$L40","\n","$L41","\n","$L42","\n","$L43","\n","$L44","\n","$L45","\n","$L46","\n","$L47","\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n","$L48","\n","$L49","\n","$L4a","\n","$L4b","\n","$L4c","\n","$L4d","\n","$L4e","\n","$L4f","\n","$L50","\n","$L51","\n","$L52","\n","$L53","\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n","$L54","\n","$L55","\n","$L56","\n","$L57","\n","$L58","\n","$L59","\n","$L5a","\n","$L5b","\n","$L5c","\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n","$L5d","\n","$L5e","\n","$L5f","\n","$L60","\n","$L61","\n","$L62","\n","$L63","\n","$L64","\n","$L65","\n","$L66","\n","$L67","\n","$L68","\n","$L69","\n","$L6a"]
