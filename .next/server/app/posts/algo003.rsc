    order = []

    while queue:
        node = queue.popleft()
        order.append(node)

        for neighbor in graph[node]:
            # 兼容带权和无权邻接表
            v = neighbor[0] if isinstance(neighbor, tuple) else neighbor
            if v not in visited:
                visited.add(v)
                queue.append(v)

    return order

# BFS 求无权图最短路径
def bfs_shortest_path(graph, start, end):
    """
    在无权图中求从 start 到 end 的最短路径
    """
    visited = {start}
    queue = deque([(start, [start])])

    while queue:
        node, path = queue.popleft()
        if node == end:
            return path

        for neighbor in graph[node]:
            v = neighbor[0] if isinstance(neighbor, tuple) else neighbor
            if v not in visited:
                visited.add(v)
                queue.append((v, path + [v]))

    return None  # 不可达
