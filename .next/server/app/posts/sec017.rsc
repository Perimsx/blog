4f:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5a",null,{"text":"# === 初始响应检查清单 ===\n\n# 1. 记录当前时间和响应人员信息\ndate\nwhoami\nhostname\n\n# 2. 采集系统基本信息\nuname -a                          # Linux 系统信息\ncat /etc/os-release               # 发行版信息\nuptime                            # 系统运行时间\n\n# 3. 检查当前登录用户\nw                                 # 查看当前登录用户及活动\nwho                               # 查看登录用户列表\nlast -n 20                        # 最近20条登录记录\n\n# 4. 快速网络状态检查\nss -tunlp                         # 查看监听端口和对应进程\nss -tunap                         # 查看所有网络连接\nip addr show                      # 查看网络接口配置\n\n# 5. 进程快速排查\nps auxf                           # 查看所有进程（树形）\nps aux --sort=-%cpu | head -20    # CPU占用排序\nps aux --sort=-%mem | head -20    # 内存占用排序\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-bash","children":"# === 初始响应检查清单 ===\n\n# 1. 记录当前时间和响应人员信息\ndate\nwhoami\nhostname\n\n# 2. 采集系统基本信息\nuname -a                          # Linux 系统信息\ncat /etc/os-release               # 发行版信息\nuptime                            # 系统运行时间\n\n# 3. 检查当前登录用户\nw                                 # 查看当前登录用户及活动\nwho                               # 查看登录用户列表\nlast -n 20                        # 最近20条登录记录\n\n# 4. 快速网络状态检查\nss -tunlp                         # 查看监听端口和对应进程\nss -tunap                         # 查看所有网络连接\nip addr show                      # 查看网络接口配置\n\n# 5. 进程快速排查\nps auxf                           # 查看所有进程（树形）\nps aux --sort=-%cpu | head -20    # CPU占用排序\nps aux --sort=-%mem | head -20    # 内存占用排序\n"}]}]]}]
51:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5a",null,{"text":"# === Windows 快速排查命令 ===\n\n# 系统基本信息\nsysteminfo\nhostname\nwhoami /all\n\n# 进程排查\nGet-Process | Sort-Object CPU -Descending | Select-Object -First 20\nwmic process list full\n\n# 网络连接排查\nnetstat -ano | findstr \"ESTABLISHED\"\nGet-NetTCPConnection | Where-Object {$_.State -eq 'Established'}\n\n# 最近修改的文件\nGet-ChildItem -Path C:\\ -Recurse -ErrorAction SilentlyContinue |\n    Where-Object {$_.LastWriteTime -gt (Get-Date).AddDays(-3)} |\n    Sort-Object LastWriteTime -Descending | Select-Object -First 50\n\n# 计划任务排查\nschtasks /query /fo LIST /v\nGet-ScheduledTask | Where-Object {$_.State -ne 'Disabled'}\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-powershell","children":"# === Windows 快速排查命令 ===\n\n# 系统基本信息\nsysteminfo\nhostname\nwhoami /all\n\n# 进程排查\nGet-Process | Sort-Object CPU -Descending | Select-Object -First 20\nwmic process list full\n\n# 网络连接排查\nnetstat -ano | findstr \"ESTABLISHED\"\nGet-NetTCPConnection | Where-Object {$_.State -eq 'Established'}\n\n# 最近修改的文件\nGet-ChildItem -Path C:\\ -Recurse -ErrorAction SilentlyContinue |\n    Where-Object {$_.LastWriteTime -gt (Get-Date).AddDays(-3)} |\n    Sort-Object LastWriteTime -Descending | Select-Object -First 50\n\n# 计划任务排查\nschtasks /query /fo LIST /v\nGet-ScheduledTask | Where-Object {$_.State -ne 'Disabled'}\n"}]}]]}]
5b:T77e,#!/bin/bash
# 应急响应证据采集脚本
# 用法: sudo bash ir_collect.sh

CASE_ID="IR-$(date +%Y%m%d-%H%M%S)"
OUTPUT_DIR="/tmp/ir_evidence/${CASE_ID}"
mkdir -p "${OUTPUT_DIR}"

echo "[*] 案例编号: ${CASE_ID}"
echo "[*] 采集时间: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"
echo "[*] 采集人员: $(whoami)@$(hostname)"

# 系统信息采集
echo "[+] 采集系统信息..."
uname -a > "${OUTPUT_DIR}/system_info.txt"
cat /etc/os-release >> "${OUTPUT_DIR}/system_info.txt"
uptime >> "${OUTPUT_DIR}/system_info.txt"

# 用户信息采集
echo "[+] 采集用户信息..."
cat /etc/passwd > "${OUTPUT_DIR}/passwd.txt"
cat /etc/shadow > "${OUTPUT_DIR}/shadow.txt" 2>/dev/null
last -a > "${OUTPUT_DIR}/last_logins.txt"
w > "${OUTPUT_DIR}/current_users.txt"

# 进程信息采集
echo "[+] 采集进程信息..."
ps auxf > "${OUTPUT_DIR}/processes.txt"
ls -la /proc/*/exe 2>/dev/null > "${OUTPUT_DIR}/proc_exe.txt"

# 网络信息采集
echo "[+] 采集网络信息..."
ss -tunap > "${OUTPUT_DIR}/network_connections.txt"
ip addr > "${OUTPUT_DIR}/ip_addresses.txt"
ip route > "${OUTPUT_DIR}/routes.txt"
iptables -L -n -v > "${OUTPUT_DIR}/iptables.txt" 2>/dev/null

# 定时任务采集
echo "[+] 采集定时任务..."
for user in $(cut -f1 -d: /etc/passwd); do
    echo "=== ${user} ===" >> "${OUTPUT_DIR}/crontabs.txt"
    crontab -l -u "${user}" 2>/dev/null >> "${OUTPUT_DIR}/crontabs.txt"
done
ls -la /etc/cron.* >> "${OUTPUT_DIR}/cron_dirs.txt" 2>/dev/null

# 自启动服务
echo "[+] 采集自启动服务..."
systemctl list-unit-files --type=service --state=enabled > "${OUTPUT_DIR}/enabled_services.txt"

# 打包证据
echo "[+] 打包证据文件..."
tar czf "/tmp/${CASE_ID}.tar.gz" -C /tmp/ir_evidence "${CASE_ID}"
sha256sum "/tmp/${CASE_ID}.tar.gz" > "/tmp/${CASE_ID}.tar.gz.sha256"

echo "[*] 证据采集完成: /tmp/${CASE_ID}.tar.gz"
echo "[*] SHA256校验值: $(cat /tmp/${CASE_ID}.tar.gz.sha256)"
5c:T77e,#!/bin/bash
# 应急响应证据采集脚本
# 用法: sudo bash ir_collect.sh

CASE_ID="IR-$(date +%Y%m%d-%H%M%S)"
OUTPUT_DIR="/tmp/ir_evidence/${CASE_ID}"
mkdir -p "${OUTPUT_DIR}"

echo "[*] 案例编号: ${CASE_ID}"
echo "[*] 采集时间: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"
echo "[*] 采集人员: $(whoami)@$(hostname)"

# 系统信息采集
echo "[+] 采集系统信息..."
uname -a > "${OUTPUT_DIR}/system_info.txt"
cat /etc/os-release >> "${OUTPUT_DIR}/system_info.txt"
uptime >> "${OUTPUT_DIR}/system_info.txt"

# 用户信息采集
echo "[+] 采集用户信息..."
cat /etc/passwd > "${OUTPUT_DIR}/passwd.txt"
cat /etc/shadow > "${OUTPUT_DIR}/shadow.txt" 2>/dev/null
last -a > "${OUTPUT_DIR}/last_logins.txt"
w > "${OUTPUT_DIR}/current_users.txt"

# 进程信息采集
echo "[+] 采集进程信息..."
ps auxf > "${OUTPUT_DIR}/processes.txt"
ls -la /proc/*/exe 2>/dev/null > "${OUTPUT_DIR}/proc_exe.txt"

# 网络信息采集
echo "[+] 采集网络信息..."
ss -tunap > "${OUTPUT_DIR}/network_connections.txt"
ip addr > "${OUTPUT_DIR}/ip_addresses.txt"
ip route > "${OUTPUT_DIR}/routes.txt"
iptables -L -n -v > "${OUTPUT_DIR}/iptables.txt" 2>/dev/null

# 定时任务采集
echo "[+] 采集定时任务..."
for user in $(cut -f1 -d: /etc/passwd); do
    echo "=== ${user} ===" >> "${OUTPUT_DIR}/crontabs.txt"
    crontab -l -u "${user}" 2>/dev/null >> "${OUTPUT_DIR}/crontabs.txt"
done
ls -la /etc/cron.* >> "${OUTPUT_DIR}/cron_dirs.txt" 2>/dev/null

# 自启动服务
echo "[+] 采集自启动服务..."
systemctl list-unit-files --type=service --state=enabled > "${OUTPUT_DIR}/enabled_services.txt"

# 打包证据
echo "[+] 打包证据文件..."
tar czf "/tmp/${CASE_ID}.tar.gz" -C /tmp/ir_evidence "${CASE_ID}"
sha256sum "/tmp/${CASE_ID}.tar.gz" > "/tmp/${CASE_ID}.tar.gz.sha256"

echo "[*] 证据采集完成: /tmp/${CASE_ID}.tar.gz"
echo "[*] SHA256校验值: $(cat /tmp/${CASE_ID}.tar.gz.sha256)"
