3d:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"# tcpdump 捕获 HTTP 流量并显示内容\nsudo tcpdump -i eth0 -nn -A -s0 'tcp port 80'\n\n# 提取 HTTP 请求的 URL\nsudo tcpdump -i eth0 -nn -A -s0 'tcp dst port 80' | grep -oP 'GET \\K[^ ]+'\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-bash","children":"# tcpdump 捕获 HTTP 流量并显示内容\nsudo tcpdump -i eth0 -nn -A -s0 'tcp port 80'\n\n# 提取 HTTP 请求的 URL\nsudo tcpdump -i eth0 -nn -A -s0 'tcp dst port 80' | grep -oP 'GET \\K[^ ]+'\n"}]}]]}]
3f:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"# 查看所有 HTTP 请求\nhttp.request\n\n# 查看包含敏感关键词的请求\nhttp.request.uri contains \"passwd\" or http.request.uri contains \"admin\"\n\n# 查看非200响应\nhttp.response.code != 200\n\n# 追踪完整 HTTP 会话：右键 → Follow → HTTP Stream\n"}],["$","div",null,{"className":"[&>pre]:!m-0","dangerouslySetInnerHTML":{"__html":"<pre class=\"shiki shiki-themes min-light night-owl\" style=\"--shiki-light:#24292eff;--shiki-dark:#d6deeb;--shiki-light-bg:#ffffff;--shiki-dark-bg:#011627\" tabindex=\"0\"><code><span class=\"line\"><span># 查看所有 HTTP 请求</span></span>\n<span class=\"line\"><span>http.request</span></span>\n<span class=\"line\"><span></span></span>\n<span class=\"line\"><span># 查看包含敏感关键词的请求</span></span>\n<span class=\"line\"><span>http.request.uri contains \"passwd\" or http.request.uri contains \"admin\"</span></span>\n<span class=\"line\"><span></span></span>\n<span class=\"line\"><span># 查看非200响应</span></span>\n<span class=\"line\"><span>http.response.code != 200</span></span>\n<span class=\"line\"><span></span></span>\n<span class=\"line\"><span># 追踪完整 HTTP 会话：右键 → Follow → HTTP Stream</span></span>\n<span class=\"line\"><span></span></span></code></pre>"}}]]}]
41:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"# tcpdump 捕获 DNS 流量\nsudo tcpdump -i eth0 -nn port 53\n\n# 提取 DNS 查询的域名\nsudo tcpdump -i eth0 -nn port 53 -l | awk '/A\\?/ {print $NF}'\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-bash","children":"# tcpdump 捕获 DNS 流量\nsudo tcpdump -i eth0 -nn port 53\n\n# 提取 DNS 查询的域名\nsudo tcpdump -i eth0 -nn port 53 -l | awk '/A\\?/ {print $NF}'\n"}]}]]}]
43:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"# 查看所有 DNS 查询\ndns.flags.response == 0\n\n# 查看 DNS 查询失败（NXDOMAIN）\ndns.flags.rcode == 3\n\n# 查看查询特定域名\ndns.qry.name contains \"suspicious-domain\"\n\n# 检测 DNS 隧道（超长域名查询）\ndns.qry.name.len > 50\n"}],["$","div",null,{"className":"[&>pre]:!m-0","dangerouslySetInnerHTML":{"__html":"<pre class=\"shiki shiki-themes min-light night-owl\" style=\"--shiki-light:#24292eff;--shiki-dark:#d6deeb;--shiki-light-bg:#ffffff;--shiki-dark-bg:#011627\" tabindex=\"0\"><code><span class=\"line\"><span># 查看所有 DNS 查询</span></span>\n<span class=\"line\"><span>dns.flags.response == 0</span></span>\n<span class=\"line\"><span></span></span>\n<span class=\"line\"><span># 查看 DNS 查询失败（NXDOMAIN）</span></span>\n<span class=\"line\"><span>dns.flags.rcode == 3</span></span>\n<span class=\"line\"><span></span></span>\n<span class=\"line\"><span># 查看查询特定域名</span></span>\n<span class=\"line\"><span>dns.qry.name contains \"suspicious-domain\"</span></span>\n<span class=\"line\"><span></span></span>\n<span class=\"line\"><span># 检测 DNS 隧道（超长域名查询）</span></span>\n<span class=\"line\"><span>dns.qry.name.len > 50</span></span>\n<span class=\"line\"><span></span></span></code></pre>"}}]]}]
61:T56c,<pre class="shiki shiki-themes min-light night-owl" style="--shiki-light:#24292eff;--shiki-dark:#d6deeb;--shiki-light-bg:#ffffff;--shiki-dark-bg:#011627" tabindex="0"><code><span class="line"><span># 查看 TLS Client Hello（获取 SNI 域名）</span></span>
<span class="line"><span>tls.handshake.type == 1</span></span>
<span class="line"><span></span></span>
<span class="line"><span># 提取 SNI（Server Name Indication）</span></span>
<span class="line"><span>tls.handshake.extensions_server_name</span></span>
<span class="line"><span></span></span>
<span class="line"><span># 查看使用的 TLS 版本</span></span>
<span class="line"><span>tls.record.version</span></span>
<span class="line"><span></span></span>
<span class="line"><span># 查看使用的密码套件</span></span>
<span class="line"><span>tls.handshake.ciphersuite</span></span>
<span class="line"><span></span></span>
<span class="line"><span># 检测弱加密套件</span></span>
<span class="line"><span>tls.handshake.ciphersuite == 0x002f    # TLS_RSA_WITH_AES_128_CBC_SHA</span></span>
<span class="line"><span></span></span>
<span class="line"><span># 查看证书信息</span></span>
<span class="line"><span>tls.handshake.type == 11               # Certificate 消息</span></span>
<span class="line"><span>tls.handshake.certificate</span></span>
<span class="line"><span></span></span></code></pre>46:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"# 查看 TLS Client Hello（获取 SNI 域名）\ntls.handshake.type == 1\n\n# 提取 SNI（Server Name Indication）\ntls.handshake.extensions_server_name\n\n# 查看使用的 TLS 版本\ntls.record.version\n\n# 查看使用的密码套件\ntls.handshake.ciphersuite\n\n# 检测弱加密套件\ntls.handshake.ciphersuite == 0x002f    # TLS_RSA_WITH_AES_128_CBC_SHA\n\n# 查看证书信息\ntls.handshake.type == 11               # Certificate 消息\ntls.handshake.certificate\n"}],["$","div",null,{"className":"[&>pre]:!m-0","dangerouslySetInnerHTML":{"__html":"$61"}}]]}]
48:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"# 设置环境变量让浏览器导出会话密钥\nexport SSLKEYLOGFILE=~/sslkeys.log\n\n# 在 Wireshark 中加载密钥：\n# Edit → Preferences → Protocols → TLS → (Pre)-Master-Secret log filename\n# 指向 ~/sslkeys.log 文件\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-bash","children":"# 设置环境变量让浏览器导出会话密钥\nexport SSLKEYLOGFILE=~/sslkeys.log\n\n# 在 Wireshark 中加载密钥：\n# Edit → Preferences → Protocols → TLS → (Pre)-Master-Secret log filename\n# 指向 ~/sslkeys.log 文件\n"}]}]]}]
