67:["$","ol",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"不确定时，使用语言标准库"}],"：现代语言标准库的排序实现经过精心优化，是大多数场景的最佳选择。"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"追求通用性能"}],"：快速排序及其变体（Introsort、pdqsort）是最佳选择。"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"需要稳定排序"}],"：选择归并排序或 Timsort。"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"内存极度受限"}],"：选择堆排序（O(1) 空间、O(n log n) 时间）。"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"数据特征明确"}],"：\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"数据范围小 → 计数排序"}],"\n",["$","li",null,{"children":"整数且位数有限 → 基数排序"}],"\n",["$","li",null,{"children":"均匀分布 → 桶排序"}],"\n",["$","li",null,{"children":"近乎有序 → 插入排序或 Timsort"}],"\n"]}],"\n"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"教学与面试"}],"：冒泡排序和选择排序适合理解排序的基本概念，但在生产环境中几乎不使用。"]}],"\n"]}]
68:["$","p",null,{"children":"理解这些算法不仅有助于选择合适的排序方案，更能培养分析问题、设计算法的思维能力。比较排序的理论下界是 O(n log n)，而非比较排序在特定条件下可以突破这一限制——这一思想本身就是算法设计中\"打破常规约束\"的精妙范例。"}]
2d:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L69",null,{"text":"def bubble_sort(arr):\n    n = len(arr)\n    for i in range(n):\n        swapped = False\n        for j in range(0, n - i - 1):\n            if arr[j] > arr[j + 1]:\n                arr[j], arr[j + 1] = arr[j + 1], arr[j]\n                swapped = True\n        if not swapped:  # 若本轮无交换，说明已有序\n            break\n    return arr\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-python","children":"def bubble_sort(arr):\n    n = len(arr)\n    for i in range(n):\n        swapped = False\n        for j in range(0, n - i - 1):\n            if arr[j] > arr[j + 1]:\n                arr[j], arr[j + 1] = arr[j + 1], arr[j]\n                swapped = True\n        if not swapped:  # 若本轮无交换，说明已有序\n            break\n    return arr\n"}]}]]}]
2e:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L69",null,{"text":"def selection_sort(arr):\n    n = len(arr)\n    for i in range(n):\n        min_idx = i\n        for j in range(i + 1, n):\n            if arr[j] < arr[min_idx]:\n                min_idx = j\n        arr[i], arr[min_idx] = arr[min_idx], arr[i]\n    return arr\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-python","children":"def selection_sort(arr):\n    n = len(arr)\n    for i in range(n):\n        min_idx = i\n        for j in range(i + 1, n):\n            if arr[j] < arr[min_idx]:\n                min_idx = j\n        arr[i], arr[min_idx] = arr[min_idx], arr[i]\n    return arr\n"}]}]]}]
2f:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L69",null,{"text":"def insertion_sort(arr):\n    for i in range(1, len(arr)):\n        key = arr[i]\n        j = i - 1\n        while j >= 0 and arr[j] > key:\n            arr[j + 1] = arr[j]\n            j -= 1\n        arr[j + 1] = key\n    return arr\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-python","children":"def insertion_sort(arr):\n    for i in range(1, len(arr)):\n        key = arr[i]\n        j = i - 1\n        while j >= 0 and arr[j] > key:\n            arr[j + 1] = arr[j]\n            j -= 1\n        arr[j + 1] = key\n    return arr\n"}]}]]}]
30:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L69",null,{"text":"def shell_sort(arr):\n    n = len(arr)\n    gap = n // 2\n    while gap > 0:\n        for i in range(gap, n):\n            temp = arr[i]\n            j = i\n            while j >= gap and arr[j - gap] > temp:\n                arr[j] = arr[j - gap]\n                j -= gap\n            arr[j] = temp\n        gap //= 2\n    return arr\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-python","children":"def shell_sort(arr):\n    n = len(arr)\n    gap = n // 2\n    while gap > 0:\n        for i in range(gap, n):\n            temp = arr[i]\n            j = i\n            while j >= gap and arr[j - gap] > temp:\n                arr[j] = arr[j - gap]\n                j -= gap\n            arr[j] = temp\n        gap //= 2\n    return arr\n"}]}]]}]
31:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L69",null,{"text":"def quick_sort(arr, low=0, high=None):\n    if high is None:\n        high = len(arr) - 1\n    if low < high:\n        pivot_idx = partition(arr, low, high)\n        quick_sort(arr, low, pivot_idx - 1)\n        quick_sort(arr, pivot_idx + 1, high)\n    return arr\n\ndef partition(arr, low, high):\n    pivot = arr[high]  # 选择最后一个元素作为基准\n    i = low - 1\n    for j in range(low, high):\n        if arr[j] <= pivot:\n            i += 1\n            arr[i], arr[j] = arr[j], arr[i]\n    arr[i + 1], arr[high] = arr[high], arr[i + 1]\n    return i + 1\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-python","children":"def quick_sort(arr, low=0, high=None):\n    if high is None:\n        high = len(arr) - 1\n    if low < high:\n        pivot_idx = partition(arr, low, high)\n        quick_sort(arr, low, pivot_idx - 1)\n        quick_sort(arr, pivot_idx + 1, high)\n    return arr\n\ndef partition(arr, low, high):\n    pivot = arr[high]  # 选择最后一个元素作为基准\n    i = low - 1\n    for j in range(low, high):\n        if arr[j] <= pivot:\n            i += 1\n            arr[i], arr[j] = arr[j], arr[i]\n    arr[i + 1], arr[high] = arr[high], arr[i + 1]\n    return i + 1\n"}]}]]}]
36:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L69",null,{"text":"def merge_sort(arr):\n    if len(arr) <= 1:\n        return arr\n    mid = len(arr) // 2\n    left = merge_sort(arr[:mid])\n    right = merge_sort(arr[mid:])\n    return merge(left, right)\n\ndef merge(left, right):\n    result = []\n    i = j = 0\n    while i < len(left) and j < len(right):\n        if left[i] <= right[j]:  # <= 保证稳定性\n            result.append(left[i])\n            i += 1\n        else:\n            result.append(right[j])\n            j += 1\n    result.extend(left[i:])\n    result.extend(right[j:])\n    return result\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-python","children":"def merge_sort(arr):\n    if len(arr) <= 1:\n        return arr\n    mid = len(arr) // 2\n    left = merge_sort(arr[:mid])\n    right = merge_sort(arr[mid:])\n    return merge(left, right)\n\ndef merge(left, right):\n    result = []\n    i = j = 0\n    while i < len(left) and j < len(right):\n        if left[i] <= right[j]:  # <= 保证稳定性\n            result.append(left[i])\n            i += 1\n        else:\n            result.append(right[j])\n            j += 1\n    result.extend(left[i:])\n    result.extend(right[j:])\n    return result\n"}]}]]}]
3c:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L69",null,{"text":"def heap_sort(arr):\n    n = len(arr)\n\n    # 构建最大堆\n    for i in range(n // 2 - 1, -1, -1):\n        heapify(arr, n, i)\n\n    # 逐个提取堆顶元素\n    for i in range(n - 1, 0, -1):\n        arr[0], arr[i] = arr[i], arr[0]\n        heapify(arr, i, 0)\n    return arr\n\ndef heapify(arr, n, i):\n    largest = i\n    left = 2 * i + 1\n    right = 2 * i + 2\n    if left < n and arr[left] > arr[largest]:\n        largest = left\n    if right < n and arr[right] > arr[largest]:\n        largest = right\n    if largest != i:\n        arr[i], arr[largest] = arr[largest], arr[i]\n        heapify(arr, n, largest)\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-python","children":"def heap_sort(arr):\n    n = len(arr)\n\n    # 构建最大堆\n    for i in range(n // 2 - 1, -1, -1):\n        heapify(arr, n, i)\n\n    # 逐个提取堆顶元素\n    for i in range(n - 1, 0, -1):\n        arr[0], arr[i] = arr[i], arr[0]\n        heapify(arr, i, 0)\n    return arr\n\ndef heapify(arr, n, i):\n    largest = i\n    left = 2 * i + 1\n    right = 2 * i + 2\n    if left < n and arr[left] > arr[largest]:\n        largest = left\n    if right < n and arr[right] > arr[largest]:\n        largest = right\n    if largest != i:\n        arr[i], arr[largest] = arr[largest], arr[i]\n        heapify(arr, n, largest)\n"}]}]]}]
42:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L69",null,{"text":"def counting_sort(arr):\n    if not arr:\n        return arr\n    max_val = max(arr)\n    min_val = min(arr)\n    range_val = max_val - min_val + 1\n\n    count = [0] * range_val\n    output = [0] * len(arr)\n\n    for num in arr:\n        count[num - min_val] += 1\n\n    # 累加计数\n    for i in range(1, range_val):\n        count[i] += count[i - 1]\n\n    # 从后向前遍历以保持稳定性\n    for i in range(len(arr) - 1, -1, -1):\n        output[count[arr[i] - min_val] - 1] = arr[i]\n        count[arr[i] - min_val] -= 1\n\n    return output\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-python","children":"def counting_sort(arr):\n    if not arr:\n        return arr\n    max_val = max(arr)\n    min_val = min(arr)\n    range_val = max_val - min_val + 1\n\n    count = [0] * range_val\n    output = [0] * len(arr)\n\n    for num in arr:\n        count[num - min_val] += 1\n\n    # 累加计数\n    for i in range(1, range_val):\n        count[i] += count[i - 1]\n\n    # 从后向前遍历以保持稳定性\n    for i in range(len(arr) - 1, -1, -1):\n        output[count[arr[i] - min_val] - 1] = arr[i]\n        count[arr[i] - min_val] -= 1\n\n    return output\n"}]}]]}]
47:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L69",null,{"text":"def bucket_sort(arr, bucket_count=10):\n    if not arr:\n        return arr\n    min_val, max_val = min(arr), max(arr)\n    bucket_range = (max_val - min_val) / bucket_count + 1\n\n    buckets = [[] for _ in range(bucket_count)]\n\n    for num in arr:\n        idx = int((num - min_val) / bucket_range)\n        buckets[idx].append(num)\n\n    result = []\n    for bucket in buckets:\n        result.extend(insertion_sort(bucket))  # 桶内使用插入排序\n    return result\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-python","children":"def bucket_sort(arr, bucket_count=10):\n    if not arr:\n        return arr\n    min_val, max_val = min(arr), max(arr)\n    bucket_range = (max_val - min_val) / bucket_count + 1\n\n    buckets = [[] for _ in range(bucket_count)]\n\n    for num in arr:\n        idx = int((num - min_val) / bucket_range)\n        buckets[idx].append(num)\n\n    result = []\n    for bucket in buckets:\n        result.extend(insertion_sort(bucket))  # 桶内使用插入排序\n    return result\n"}]}]]}]
4c:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L69",null,{"text":"def radix_sort(arr):\n    if not arr:\n        return arr\n    max_val = max(arr)\n    exp = 1\n    while max_val // exp > 0:\n        counting_sort_by_digit(arr, exp)\n        exp *= 10\n    return arr\n\ndef counting_sort_by_digit(arr, exp):\n    n = len(arr)\n    output = [0] * n\n    count = [0] * 10\n\n    for num in arr:\n        idx = (num // exp) % 10\n        count[idx] += 1\n\n    for i in range(1, 10):\n        count[i] += count[i - 1]\n\n    for i in range(n - 1, -1, -1):\n        idx = (arr[i] // exp) % 10\n        output[count[idx] - 1] = arr[i]\n        count[idx] -= 1\n\n    for i in range(n):\n        arr[i] = output[i]\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-python","children":"def radix_sort(arr):\n    if not arr:\n        return arr\n    max_val = max(arr)\n    exp = 1\n    while max_val // exp > 0:\n        counting_sort_by_digit(arr, exp)\n        exp *= 10\n    return arr\n\ndef counting_sort_by_digit(arr, exp):\n    n = len(arr)\n    output = [0] * n\n    count = [0] * 10\n\n    for num in arr:\n        idx = (num // exp) % 10\n        count[idx] += 1\n\n    for i in range(1, 10):\n        count[i] += count[i - 1]\n\n    for i in range(n - 1, -1, -1):\n        idx = (arr[i] // exp) % 10\n        output[count[idx] - 1] = arr[i]\n        count[idx] -= 1\n\n    for i in range(n):\n        arr[i] = output[i]\n"}]}]]}]
