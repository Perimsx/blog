2b:["$","div",null,{"className":"flex flex-col sm:flex-row justify-between gap-6","children":[["$","$L5",null,{"href":"/posts/sec024","className":"flex gap-2 hover:opacity-75 items-start","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M15 6l-6 6l6 6"}]]}],["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"上一篇"}],["$","div",null,{"className":"text-accent/85","children":"Linux服务漏洞利用"}]]}]]}],["$","$L5",null,{"href":"/posts/sec022","className":"flex gap-2 hover:opacity-75 items-start justify-end text-right ml-auto","children":[["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"下一篇"}],["$","div",null,{"className":"text-accent/85","children":"Kali环境搭建指南"}]]}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M9 6l6 6l-6 6"}]]}]]}]]}]
25:[["$","blockquote",null,{"children":["\n",["$","p",null,{"children":"阅读提示\n适合对象：渗透测试入门者和需要系统化整理侦察流程的读者。\n阅读前提：了解域名、端口、常见服务和命令行环境。\n核心收获：把被动侦察、主动探测和结果整理串成完整流程。\n说明：扫描参数与工具输出会随版本变化，授权范围内操作前请先确认目标边界。"}],"\n"]}],"\n",["$","p",null,{"children":"信息收集是渗透测试的第一阶段，也是最关键的阶段之一。充分的信息收集能够帮助渗透测试人员全面了解目标的攻击面，发现潜在的薄弱环节。正如安全圈的一句老话：\"知己知彼，百战不殆。\"本文将系统地介绍被动信息收集与主动信息收集的方法论，并深入讲解 Nmap、Recon-ng 等核心工具的高级用法，帮助你构建完整的信息侦察能力。"}],"\n",["$","h2",null,{"id":"信息收集方法论","children":["信息收集方法论",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#信息收集方法论","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"信息收集从大的维度上可以分为两类："}],"\n",["$","h3",null,{"id":"被动信息收集passive-reconnaissance","children":["被动信息收集（Passive Reconnaissance）",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#被动信息收集passive-reconnaissance","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"不与目标系统直接交互，通过公开渠道获取情报。目标不会感知到侦察行为，隐蔽性极高。"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"WHOIS 查询、DNS 记录"}],"\n",["$","li",null,{"children":"搜索引擎（Google Hacking）"}],"\n",["$","li",null,{"children":"社交媒体和招聘信息"}],"\n",["$","li",null,{"children":"公开代码仓库（GitHub）"}],"\n",["$","li",null,{"children":"证书透明度日志（Certificate Transparency）"}],"\n",["$","li",null,{"children":"网络空间搜索引擎（Shodan、Censys、FOFA）"}],"\n"]}],"\n",["$","h3",null,{"id":"主动信息收集active-reconnaissance","children":["主动信息收集（Active Reconnaissance）",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#主动信息收集active-reconnaissance","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"直接与目标系统交互，发送探测数据包，获取更详细的技术信息。目标可能会在日志中记录这些行为。"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"端口扫描（Nmap）"}],"\n",["$","li",null,{"children":"服务版本探测"}],"\n",["$","li",null,{"children":"操作系统识别"}],"\n",["$","li",null,{"children":"Web 目录枚举"}],"\n",["$","li",null,{"children":"漏洞扫描"}],"\n"]}],"\n",["$","h2",null,{"id":"被动信息收集实战","children":["被动信息收集实战",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#被动信息收集实战","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","h3",null,{"id":"whois-查询","children":["WHOIS 查询",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#whois-查询","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"WHOIS 可以获取域名注册信息，包括注册人、注册商、DNS 服务器、注册日期等。"}],"\n","$L2d","\n",["$","h3",null,{"id":"dns-信息收集","children":["DNS 信息收集",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#dns-信息收集","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"DNS 记录中隐藏着大量有价值的信息：A 记录指向服务器 IP、MX 记录揭示邮件服务器、TXT 记录可能包含 SPF 配置等。"}],"\n","$L2e","\n",["$","h3",null,{"id":"google-hackinggoogle-dorks","children":["Google Hacking（Google Dorks）",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#google-hackinggoogle-dorks","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"利用搜索引擎高级语法发现目标的敏感信息："}],"\n","$L2f","\n",["$","h3",null,{"id":"shodan--网络空间搜索引擎","children":["Shodan — 网络空间搜索引擎",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#shodan--网络空间搜索引擎","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"Shodan 是物联网设备和网络服务的搜索引擎，可以发现暴露在互联网上的各种设备和服务。"}],"\n","$L30","\n",["$","h3",null,{"id":"证书透明度与子域名发现","children":["证书透明度与子域名发现",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#证书透明度与子域名发现","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L31","\n",["$","h2",null,{"id":"nmap-扫描技术大全","children":["Nmap 扫描技术大全",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#nmap-扫描技术大全","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"Nmap（Network Mapper）是最强大的网络扫描工具，掌握其各种扫描技术是渗透测试的基本功。"}],"\n",["$","h3",null,{"id":"主机发现","children":["主机发现",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#主机发现","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L32","\n",["$","h3",null,{"id":"端口扫描技术","children":["端口扫描技术",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#端口扫描技术","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L33","\n",["$","h3",null,{"id":"版本探测与操作系统识别","children":["版本探测与操作系统识别",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#版本探测与操作系统识别","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L34","\n",["$","h3",null,{"id":"nse-脚本引擎","children":["NSE 脚本引擎",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#nse-脚本引擎","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"Nmap Scripting Engine（NSE）是 Nmap 的灵魂，拥有数百个脚本。"}],"\n","$L35","\n",["$","h3",null,{"id":"扫描速度与隐蔽性","children":["扫描速度与隐蔽性","$L36"]}],"\n","$L37","\n","$L38","\n","$L39","\n","$L3a","\n","$L3b","\n","$L3c","\n","$L3d","\n","$L3e","\n","$L3f","\n","$L40","\n","$L41","\n","$L42","\n","$L43","\n","$L44","\n","$L45","\n","$L46","\n","$L47","\n","$L48"]
