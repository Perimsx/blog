3d:["$","ol",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"SDP 发起主机"}],"（客户端）向 ",["$","strong",null,{"children":"SDP 控制器"}],"发起认证请求"]}],"\n",["$","li",null,{"children":"控制器验证身份、检查设备状态、评估安全策略"}],"\n",["$","li",null,{"children":"认证通过后，控制器向客户端下发可访问的服务列表和连接信息"}],"\n",["$","li",null,{"children":["客户端与 ",["$","strong",null,{"children":"SDP 网关"}],"建立加密隧道，访问授权的应用"]}],"\n",["$","li",null,{"children":"未经认证的用户甚至无法发现服务的存在（\"暗网\"概念）"}],"\n"]}]
