3e:["$","p",null,{"children":"纵深防御是一种经典的安全策略，通过在不同层面部署多重安全措施来提供全面保护。即使某一层防御被突破，后续层次的防御仍然能够发挥作用。"}]
3f:["$","p",null,{"children":"典型的纵深防御层次包括："}]
40:["$","ol",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"物理安全"}],"：门禁系统、监控摄像头、生物识别"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"网络安全"}],"：防火墙、IDS/IPS、网络分段"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"主机安全"}],"：操作系统加固、防病毒软件、主机入侵检测"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"应用安全"}],"：WAF、安全编码、渗透测试"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"数据安全"}],"：加密、DLP（数据防泄漏）、备份"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"安全管理"}],"：策略制度、安全培训、应急响应"]}],"\n"]}]
41:["$","h3",null,{"id":"最小权限原则principle-of-least-privilege","children":["最小权限原则（Principle of Least Privilege）",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#最小权限原则principle-of-least-privilege","children":["$","span",null,{"children":"#"}]}]]}]
42:["$","p",null,{"children":"每个用户、程序和系统只应获得完成其任务所需的最低限度的访问权限。这一原则能有效限制安全事件的影响范围。"}]
44:["$","h3",null,{"id":"零信任架构zero-trust","children":["零信任架构（Zero Trust）",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#零信任架构zero-trust","children":["$","span",null,{"children":"#"}]}]]}]
45:["$","p",null,{"children":"零信任的核心理念是\"永不信任，始终验证\"（Never Trust, Always Verify）。不再基于网络边界来划分信任区域，而是对每一次访问请求都进行身份验证和授权检查。"}]
46:["$","p",null,{"children":"零信任的关键原则："}]
47:["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"验证每个用户和设备"}],"：无论位于网络内外，都需要经过严格认证"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"最小权限访问"}],"：仅授予完成任务所需的最低权限"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"微分段（Micro-segmentation）"}],"：将网络划分为细粒度的安全区域"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"持续监控和验证"}],"：实时检测异常行为，动态调整访问策略"]}],"\n"]}]
