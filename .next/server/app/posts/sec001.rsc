2d:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L56",null,{"text":"# 安装 ClamAV\nsudo apt install clamav clamav-daemon\n\n# 更新病毒库\nsudo freshclam\n\n# 扫描指定目录\nclamscan -r /home/user/downloads/\n\n# 扫描并删除感染文件\nclamscan -r --remove /tmp/suspicious/\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-bash","children":"# 安装 ClamAV\nsudo apt install clamav clamav-daemon\n\n# 更新病毒库\nsudo freshclam\n\n# 扫描指定目录\nclamscan -r /home/user/downloads/\n\n# 扫描并删除感染文件\nclamscan -r --remove /tmp/suspicious/\n"}]}]]}]
35:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L56",null,{"text":"# 扫描目标主机的常用端口\nnmap -sV 192.168.1.0/24\n\n# 扫描全端口并识别操作系统\nnmap -sS -p- -O 192.168.1.100\n\n# 使用脚本扫描检测已知漏洞\nnmap --script vuln 192.168.1.100\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-bash","children":"# 扫描目标主机的常用端口\nnmap -sV 192.168.1.0/24\n\n# 扫描全端口并识别操作系统\nnmap -sS -p- -O 192.168.1.100\n\n# 使用脚本扫描检测已知漏洞\nnmap --script vuln 192.168.1.100\n"}]}]]}]
43:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L56",null,{"text":"# Linux 中实践最小权限原则的示例\n\n# 为 Web 服务创建专用低权限用户\nsudo useradd -r -s /sbin/nologin webservice\n\n# 设置目录权限 — 仅 owner 可读写执行\nchmod 700 /var/www/private/\n\n# 使用 sudo 授予特定命令权限而非 root 权限\necho \"deploy ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart nginx\" >> /etc/sudoers.d/deploy\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-bash","children":"# Linux 中实践最小权限原则的示例\n\n# 为 Web 服务创建专用低权限用户\nsudo useradd -r -s /sbin/nologin webservice\n\n# 设置目录权限 — 仅 owner 可读写执行\nchmod 700 /var/www/private/\n\n# 使用 sudo 授予特定命令权限而非 root 权限\necho \"deploy ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart nginx\" >> /etc/sudoers.d/deploy\n"}]}]]}]
4c:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L56",null,{"text":"# 快速扫描目标的开放端口\nnmap -F 10.0.0.1\n\n# 服务版本探测\nnmap -sV -p 22,80,443 10.0.0.1\n\n# 使用 NSE 脚本进行漏洞检测\nnmap --script=http-vuln* -p 80 10.0.0.1\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-bash","children":"# 快速扫描目标的开放端口\nnmap -F 10.0.0.1\n\n# 服务版本探测\nnmap -sV -p 22,80,443 10.0.0.1\n\n# 使用 NSE 脚本进行漏洞检测\nnmap --script=http-vuln* -p 80 10.0.0.1\n"}]}]]}]
4f:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L56",null,{"text":"# 命令行版本 tshark 的使用示例\n\n# 捕获指定接口的流量并保存\ntshark -i eth0 -w capture.pcap\n\n# 读取并过滤 HTTP 流量\ntshark -r capture.pcap -Y \"http.request\"\n\n# 分析 DNS 查询\ntshark -r capture.pcap -Y \"dns.qry.name\" -T fields -e dns.qry.name\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-bash","children":"# 命令行版本 tshark 的使用示例\n\n# 捕获指定接口的流量并保存\ntshark -i eth0 -w capture.pcap\n\n# 读取并过滤 HTTP 流量\ntshark -r capture.pcap -Y \"http.request\"\n\n# 分析 DNS 查询\ntshark -r capture.pcap -Y \"dns.qry.name\" -T fields -e dns.qry.name\n"}]}]]}]
