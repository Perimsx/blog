5a:["$","ul",null,{"children":["\n",["$","li",null,{"children":"Meta（Facebook）因违反 GDPR 被爱尔兰数据保护委员会处以 12 亿欧元罚款"}],"\n",["$","li",null,{"children":"Amazon 因违反 GDPR 的数据处理规则被卢森堡国家数据保护委员会处以 7.46 亿欧元罚款"}],"\n",["$","li",null,{"children":"British Airways 因数据泄露事件被英国信息专员办公室（ICO）处以 2000 万英镑罚款"}],"\n"]}]
