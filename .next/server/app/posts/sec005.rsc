2e:["$","div",null,{"className":"flex flex-col sm:flex-row justify-between gap-6","children":[["$","$L5",null,{"href":"/posts/sec007","className":"flex gap-2 hover:opacity-75 items-start","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M15 6l-6 6l6 6"}]]}],["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"上一篇"}],["$","div",null,{"className":"text-accent/85","children":"IDS/IPS部署实战"}]]}]]}],["$","$L5",null,{"href":"/posts/sec004","className":"flex gap-2 hover:opacity-75 items-start justify-end text-right ml-auto","children":[["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"下一篇"}],["$","div",null,{"className":"text-accent/85","children":"密码学基础与应用"}]]}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M9 6l6 6l-6 6"}]]}]]}]]}]
25:[["$","blockquote",null,{"children":["\n",["$","p",null,{"children":"阅读提示\n适合对象：在做安全治理、制度建设与法规对照的管理者和从业者。\n阅读前提：了解组织安全制度、数据分类或等级保护的基本概念。\n核心收获：建立国内外主要合规框架的阅读顺序和落地视角。\n说明：法规、配套标准和监管口径可能更新，正式落地时应核对最新法规文本。"}],"\n"]}],"\n",["$","p",null,{"children":"技术手段只是网络安全的一个维度，法律法规和合规要求则构成了安全体系的制度保障。近年来，全球各国纷纷出台和完善网络安全相关法律，中国也形成了以《网络安全法》为核心、多部法律法规协同配合的网络安全法律体系。对于企业和安全从业者而言，了解并遵守这些法规不仅是法律义务，更是保护用户权益和维护企业声誉的基本要求。本文将系统梳理国内外主要的网络安全法律法规，并探讨企业合规实践的要点。"}],"\n",["$","h2",null,{"id":"中国网络安全法","children":["中国网络安全法",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#中国网络安全法","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"《中华人民共和国网络安全法》于 2017 年 6 月 1 日正式施行，是中国网络空间安全治理的基础性法律。"}],"\n",["$","h3",null,{"id":"核心内容","children":["核心内容",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#核心内容","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":["$","strong",null,{"children":"网络运营者的安全义务"}]}],"\n",["$","p",null,{"children":"网络运营者是指网络的所有者、管理者和网络服务提供者。法律规定了以下主要义务："}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"制定内部安全管理制度和操作规程"}],"\n",["$","li",null,{"children":"确定网络安全负责人，落实网络安全保护责任"}],"\n",["$","li",null,{"children":"采取技术措施防范计算机病毒和网络攻击、网络入侵等"}],"\n",["$","li",null,{"children":"采取数据分类、重要数据备份和加密等措施"}],"\n",["$","li",null,{"children":"监测、记录网络运行状态和网络安全事件，留存网络日志不少于六个月"}],"\n"]}],"\n",["$","p",null,{"children":["$","strong",null,{"children":"关键信息基础设施保护"}]}],"\n",["$","p",null,{"children":"关键信息基础设施（CII）涵盖公共通信和信息服务、能源、交通、水利、金融、公共服务、电子政务等重要行业和领域。CII 运营者需要满足更高的安全要求："}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"设置专门安全管理机构和安全管理负责人"}],"\n",["$","li",null,{"children":"定期进行网络安全检测和风险评估"}],"\n",["$","li",null,{"children":"重要数据应当在境内存储，确需出境的须经安全评估"}],"\n",["$","li",null,{"children":"采购网络产品和服务可能影响国家安全的，须通过安全审查"}],"\n"]}],"\n",["$","p",null,{"children":["$","strong",null,{"children":"个人信息保护"}]}],"\n",["$","p",null,{"children":"网络安全法对个人信息保护作出了明确规定："}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"收集和使用个人信息需遵循合法、正当、必要原则"}],"\n",["$","li",null,{"children":"需明示收集、使用信息的目的、方式和范围，并经被收集者同意"}],"\n",["$","li",null,{"children":"不得泄露、篡改、毁损其收集的个人信息"}],"\n",["$","li",null,{"children":"发生或可能发生个人信息泄露时，应立即采取补救措施并告知用户"}],"\n"]}],"\n",["$","h3",null,{"id":"法律责任","children":["法律责任",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#法律责任","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"违反网络安全法的处罚力度相当严厉："}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"不履行安全保护义务：责令改正，警告；拒不改正或导致安全事件的，处一万元以上十万元以下罚款，对直接负责人处五千元以上五万元以下罚款"}],"\n",["$","li",null,{"children":"关键信息基础设施运营者违规：处十万元以上一百万元以下罚款，对直接负责人处一万元以上十万元以下罚款"}],"\n",["$","li",null,{"children":"窃取或非法获取个人信息：构成犯罪的，依法追究刑事责任"}],"\n"]}],"\n",["$","h2",null,{"id":"等保-20网络安全等级保护","children":["等保 2.0（网络安全等级保护）",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#等保-20网络安全等级保护","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"网络安全等级保护制度（简称\"等保\"）是中国网络安全的基本制度。等保 2.0 于 2019 年 12 月 1 日正式实施，标准号为 GB/T 22239-2019。"}],"\n",["$","h3",null,{"id":"五个保护级别","children":["五个保护级别",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#五个保护级别","children":["$","span",null,{"children":"#"}]}]]}],"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n",["$","table",null,{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th",null,{"children":"级别"}],["$","th",null,{"children":"名称"}],["$","th",null,{"children":"保护对象"}],["$","th",null,{"children":"受损影响"}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"children":[["$","td",null,{"children":"第一级"}],["$","td",null,{"children":"用户自主保护级"}],["$","td",null,{"children":"一般网络"}],["$","td",null,{"children":"损害公民、法人权益"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"第二级"}],["$","td",null,{"children":"系统审计保护级"}],["$","td",null,{"children":"一般网络"}],["$","td",null,{"children":"严重损害公民、法人权益或损害社会秩序"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"第三级"}],["$","td",null,{"children":"安全标记保护级"}],["$","td",null,{"children":"重要网络"}],["$","td",null,{"children":"严重损害社会秩序或损害公共利益"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"第四级"}],["$","td",null,{"children":"结构化保护级"}],["$","td",null,{"children":"极重要网络"}],["$","td",null,{"children":"严重损害公共利益或损害国家安全"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"第五级"}],["$","td",null,{"children":"访问验证保护级"}],["$","td",null,{"children":"极端重要网络"}],["$","td",null,{"children":"严重损害国家安全"}]]}]]}]]}],"\n",["$","p",null,{"children":["大多数企业的信息系统需要达到",["$","strong",null,{"children":"第二级"}],"或",["$","strong",null,{"children":"第三级"}],"的安全保护要求。其中，第三级系统（又称\"三级等保\"）在实践中最为常见，也是监管重点。"]}],"\n",["$","h3",null,{"id":"等保测评流程","children":["等保测评流程",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#等保测评流程","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L30","\n","$L31","\n","$L32","\n","$L33","\n","$L34","\n","$L35","\n","$L36","\n","$L37","\n","$L38","\n","$L39","\n","$L3a","\n","$L3b","\n","$L3c","\n","$L3d","\n","$L3e","\n","$L3f","\n","$L40","\n","$L41","\n","$L42","\n","$L43","\n","$L44","\n","$L45","\n","$L46","\n","$L47","\n","$L48","\n","$L49","\n","$L4a","\n","$L4b","\n","$L4c","\n","$L4d","\n","$L4e","\n","$L4f","\n","$L50","\n","$L51","\n","$L52","\n","$L53","\n","$L54","\n","$L55","\n","$L56","\n","$L57","\n","$L58","\n","$L59","\n","$L5a","\n","$L5b","\n","$L5c","\n","$L5d","\n","$L5e","\n","$L5f"]
