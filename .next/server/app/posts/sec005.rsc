46:["$","p",null,{"children":"ISO/IEC 27001 是信息安全管理体系（ISMS）的国际标准，为组织建立、实施、维护和持续改进信息安全管理体系提供了框架。"}]
47:["$","p",null,{"children":"ISO 27001 的核心要素："}]
48:["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"风险评估与处置"}],"：识别信息安全风险，评估其可能性和影响，制定处置措施"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"安全控制"}],"：包含 93 个控制措施（2022 版），涵盖组织控制、人员控制、物理控制和技术控制"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"持续改进"}],"：通过 PDCA（Plan-Do-Check-Act）循环不断优化安全管理体系"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"管理层承诺"}],"：要求最高管理层证明对信息安全管理体系的领导力和承诺"]}],"\n"]}]
49:["$","p",null,{"children":"获得 ISO 27001 认证不仅能提升组织的安全管理水平，还能增强客户和合作伙伴的信任，在某些行业和地区甚至是参与招标或开展业务的前提条件。"}]
