58:["$","ul",null,{"children":["\n",["$","li",null,{"children":"某网约车平台因违法收集处理个人信息，被处以 80.26 亿元罚款，直接责任人被罚 100 万元"}],"\n",["$","li",null,{"children":"某社交平台因未按规定留存用户日志信息，被公安机关依据《网络安全法》予以行政处罚"}],"\n",["$","li",null,{"children":"某医疗机构信息系统未进行等级保护测评且存在严重安全隐患，被责令限期整改并处罚款"}],"\n"]}]
