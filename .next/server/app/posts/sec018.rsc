4f:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L54",null,{"text":":: 导出所有自启动项为 CSV 格式\nautorunsc.exe -a * -c -h -s -v > C:\\IR\\autoruns.csv\n\n:: 只显示非微软签名的条目\nautorunsc.exe -a * -m -c -h -s > C:\\IR\\autoruns_nonms.csv\n\n:: 对比两次扫描结果\nautorunsc.exe -a * -c -h -s > C:\\IR\\autoruns_after.csv\n:: 使用 diff 工具对比 autoruns_before.csv 和 autoruns_after.csv\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-cmd","children":":: 导出所有自启动项为 CSV 格式\nautorunsc.exe -a * -c -h -s -v > C:\\IR\\autoruns.csv\n\n:: 只显示非微软签名的条目\nautorunsc.exe -a * -m -c -h -s > C:\\IR\\autoruns_nonms.csv\n\n:: 对比两次扫描结果\nautorunsc.exe -a * -c -h -s > C:\\IR\\autoruns_after.csv\n:: 使用 diff 工具对比 autoruns_before.csv 和 autoruns_after.csv\n"}]}]]}]
