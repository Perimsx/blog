2f:["$","div",null,{"className":"flex flex-col sm:flex-row justify-between gap-6","children":[["$","$L5",null,{"href":"/posts/sec030","className":"flex gap-2 hover:opacity-75 items-start","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M15 6l-6 6l6 6"}]]}],["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"上一篇"}],["$","div",null,{"className":"text-accent/85","children":"Windows提权技术实战"}]]}]]}],["$","$L5",null,{"href":"/posts/sec028","className":"flex gap-2 hover:opacity-75 items-start justify-end text-right ml-auto","children":[["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"下一篇"}],["$","div",null,{"className":"text-accent/85","children":"Windows渗透环境搭建"}]]}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M9 6l6 6l-6 6"}]]}]]}]]}]
25:[["$","blockquote",null,{"children":["\n",["$","p",null,{"children":"阅读提示\n适合对象：在做 Windows 服务安全测试、枚举和加固排查的读者。\n阅读前提：了解 SMB、RDP、WinRM、MSSQL 等常见 Windows 服务。\n核心收获：识别高风险端口暴露点及对应的攻击和缓解路径。\n说明：具体利用结果依赖于补丁、认证策略和服务配置。"}],"\n"]}],"\n",["$","p",null,{"children":"Windows 系统运行着众多网络服务，每一个开放的端口都可能成为攻击者的突破口。在上一篇完成信息收集之后，本文将深入讲解 Windows 环境中最常见的服务攻击面，包括 SMB、RDP、WinRM、MSSQL 和 IIS，从漏洞原理到实战利用，再到对应的安全加固措施，构建完整的攻击与防御知识框架。"}],"\n",["$","h2",null,{"id":"smb-协议攻击","children":["SMB 协议攻击",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#smb-协议攻击","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"SMB（Server Message Block）协议是 Windows 网络的核心组成部分，负责文件共享、打印服务和进程间通信。由于其广泛部署和协议复杂性，SMB 历来是 Windows 渗透测试中最重要的攻击向量。"}],"\n",["$","h3",null,{"id":"ms17-010-永恒之蓝eternalblue","children":["MS17-010 永恒之蓝（EternalBlue）",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#ms17-010-永恒之蓝eternalblue","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"MS17-010 是 2017 年由 Shadow Brokers 泄露的 NSA 武器库中最具破坏力的漏洞之一。该漏洞存在于 SMBv1 协议的事务处理中，允许攻击者通过发送特制数据包实现远程代码执行。"}],"\n","$L31","\n",["$","p",null,{"children":"对于不使用 Metasploit 的场景，可以使用独立的漏洞利用脚本："}],"\n","$L32","\n",["$","h3",null,{"id":"smb-签名绕过与中继攻击","children":["SMB 签名绕过与中继攻击",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#smb-签名绕过与中继攻击","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"当 Windows 主机未强制启用 SMB 签名时，攻击者可以执行 NTLM 中继攻击，将截获的认证凭据转发到其他主机，从而实现无需密码的横向移动。"}],"\n","$L33","\n",["$","h3",null,{"id":"smb-密码攻击","children":["SMB 密码攻击",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#smb-密码攻击","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L34","\n",["$","h2",null,{"id":"rdp-攻击","children":["RDP 攻击",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#rdp-攻击","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"远程桌面协议（RDP，端口 3389）是 Windows 系统最常用的远程管理手段，也是暴力破解和漏洞利用的重点目标。"}],"\n",["$","h3",null,{"id":"暴力破解","children":["暴力破解",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#暴力破解","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L35","\n",["$","h3",null,{"id":"bluekeepcve-2019-0708","children":["BlueKeep（CVE-2019-0708）",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#bluekeepcve-2019-0708","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"BlueKeep 是 RDP 协议中的高危远程代码执行漏洞，影响 Windows 7、Windows Server 2008/2008 R2 等系统，无需认证即可利用。"}],"\n","$L36","\n",["$","h3",null,{"id":"rdp-会话劫持","children":["RDP 会话劫持",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#rdp-会话劫持","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"当已获得 SYSTEM 权限时，可以劫持其他用户的 RDP 会话而无需其密码："}],"\n","$L37","\n",["$","h2",null,{"id":"winrm-利用","children":["WinRM 利用",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#winrm-利用","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"WinRM（Windows Remote Management，端口 5985/5986）是 Windows 的远程管理框架，提供了强大的远程命令执行能力。"}],"\n",["$","h3",null,{"id":"evil-winrm","children":["evil-winrm",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#evil-winrm","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"evil-winrm 是专为渗透测试设计的 WinRM 客户端，功能远超普通 WinRM 连接。"}],"\n","$L38","\n","$L39","\n",["$","h2",null,{"id":"mssql-攻击","children":["MSSQL 攻击",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#mssql-攻击","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"Microsoft SQL Server（端口 1433）在企业环境中广泛部署，其强大的存储过程机制使其成为获取系统命令执行的重要途径。"}],"\n","$L3a","\n",["$","h3",null,{"id":"mssql-提权路径","children":["MSSQL 提权路径",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#mssql-提权路径","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L3b","\n",["$","h2",null,{"id":"iis-漏洞利用","children":["IIS 漏洞利用",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#iis-漏洞利用","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"IIS（Internet Information Services）是 Windows 自带的 Web 服务器，常见的攻击面包括："}],"\n","$L3c","\n",["$","h2",null,{"id":"安全加固建议","children":["安全加固建议",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#安全加固建议","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"针对上述各服务的攻击面，建议采取以下防御措施："}],"\n",["$","h3",null,{"id":"smb-加固","children":["SMB 加固","$L3d"]}],"\n","$L3e","\n","$L3f","\n","$L40","\n","$L41","\n","$L42","\n","$L43","\n","$L44","\n","$L45","\n","$L46","\n","$L47","\n","$L48","\n","$L49"]
