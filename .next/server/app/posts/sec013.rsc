2f:["$","div",null,{"className":"flex flex-col sm:flex-row justify-between gap-6","children":[["$","$L5",null,{"href":"/posts/sec014","className":"flex gap-2 hover:opacity-75 items-start","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M15 6l-6 6l6 6"}]]}],["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"上一篇"}],["$","div",null,{"className":"text-accent/85","children":"恶意软件分析入门"}]]}]]}],["$","$L5",null,{"href":"/posts/sec012","className":"flex gap-2 hover:opacity-75 items-start justify-end text-right ml-auto","children":[["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"下一篇"}],["$","div",null,{"className":"text-accent/85","children":"威胁情报与ATT&CK"}]]}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M9 6l6 6l-6 6"}]]}]]}]]}]
25:[["$","blockquote",null,{"children":["\n",["$","p",null,{"children":"阅读提示\n适合对象：打算自建日志平台、告警平台或安全分析环境的读者。\n阅读前提：了解日志类型、Linux 服务部署与基本网络概念。\n核心收获：把 ELK / SIEM 从概念、部署到告警分析串成完整路径。\n说明：Elastic 生态的配置项与许可证策略可能随版本调整。"}],"\n"]}],"\n",["$","p",null,{"children":"安全事件的发现与溯源离不开日志。日志记录了系统中发生的每一个关键事件，是安全分析师的\"黑匣子\"。然而，面对海量日志数据，人工逐条审查既不现实也不高效。SIEM（安全信息和事件管理）系统应运而生，它将日志收集、存储、分析和告警集于一体。本文将深入讲解日志分析基础、SIEM 核心概念，并通过 ELK Stack（Elasticsearch + Logstash + Kibana）的完整部署实战，带你从零搭建一套功能完备的日志分析平台。"}],"\n",["$","h2",null,{"id":"日志的重要性与类型","children":["日志的重要性与类型",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#日志的重要性与类型","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"日志是系统运行过程中自动产生的时间序列记录，在安全领域承担着多重角色：事件检测、入侵调查、合规审计和取证分析。没有完善的日志体系，安全团队就如同蒙着眼睛战斗。"}],"\n",["$","h3",null,{"id":"常见日志类型","children":["常见日志类型",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#常见日志类型","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"系统日志（System Logs）"}],"：记录操作系统层面的事件，如服务启停、用户登录、系统错误。Linux 下典型的有 ",["$","code",null,{"children":"/var/log/syslog"}],"、",["$","code",null,{"children":"/var/log/messages"}],"；Windows 下则是事件查看器中的系统日志。"]}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"安全日志（Security Logs）"}],"：专门记录与安全相关的事件，如认证成功/失败、权限变更、策略修改。Linux 下为 ",["$","code",null,{"children":"/var/log/auth.log"}]," 或 ",["$","code",null,{"children":"/var/log/secure"}],"；Windows 安全日志记录登录事件（Event ID 4624/4625）、账户管理等关键操作。"]}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"应用日志（Application Logs）"}],"：各类应用程序产生的日志，如 Web 服务器访问日志（Nginx/Apache access.log）、数据库查询日志、中间件运行日志。格式各异，是 Web 安全分析的重要数据源。"]}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"网络日志（Network Logs）"}],"：防火墙日志、IDS/IPS 告警日志、DNS 查询日志、NetFlow 流量记录。这些日志对于检测网络层面的异常行为至关重要。"]}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"审计日志（Audit Logs）"}],"：记录用户对关键资源的操作行为，满足合规要求（如 PCI DSS、等保2.0）。Linux 的 auditd 和 Windows 的高级审核策略都提供细粒度的审计能力。"]}],"\n",["$","h2",null,{"id":"siem-概念与核心功能","children":["SIEM 概念与核心功能",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#siem-概念与核心功能","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"SIEM（Security Information and Event Management）是将安全信息管理（SIM）和安全事件管理（SEM）融合在一起的综合平台。其核心功能包括："}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"日志聚合"}],"：从多种数据源集中收集日志，统一存储和管理"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"实时监控"}],"：对收集的日志进行实时分析和展示"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"关联分析"}],"：跨数据源关联事件，识别复杂攻击链"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"告警通知"}],"：基于预定义规则或异常检测自动触发告警"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"仪表盘"}],"：通过可视化面板直观展示安全态势"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"合规报告"}],"：自动生成满足法规要求的审计报告"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"事件响应"}],"：与 SOAR 平台集成，实现自动化响应"]}],"\n"]}],"\n",["$","h2",null,{"id":"elk-stack-组件详解","children":["ELK Stack 组件详解",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#elk-stack-组件详解","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"ELK Stack 是开源日志分析领域最流行的技术栈，由三个核心组件构成："}],"\n",["$","h3",null,{"id":"elasticsearch","children":["Elasticsearch",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#elasticsearch","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"Elasticsearch 是基于 Apache Lucene 的分布式搜索和分析引擎。它是 ELK 的核心存储和检索层，具备以下特点："}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"分布式架构，支持水平扩展"}],"\n",["$","li",null,{"children":"近实时（NRT）搜索和分析"}],"\n",["$","li",null,{"children":"RESTful API 接口"}],"\n",["$","li",null,{"children":"强大的全文检索和聚合分析能力"}],"\n",["$","li",null,{"children":"支持结构化和非结构化数据"}],"\n"]}],"\n",["$","h3",null,{"id":"logstash","children":["Logstash",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#logstash","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"Logstash 是服务端数据处理管道，负责日志的采集、转换和输出。它的处理流程分为三个阶段："}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"Input（输入）"}],"：从各种数据源接收数据（文件、syslog、Beats、Kafka 等）"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Filter（过滤）"}],"：解析、转换和丰富数据（Grok 模式匹配、GeoIP 地理定位、日期解析等）"]}],"\n",["$","li",null,{"children":["$L31","：将处理后的数据发送到目的地（Elasticsearch、文件、邮件等）"]}],"\n"]}],"\n","$L32","\n","$L33","\n","$L34","\n","$L35","\n","$L36","\n","$L37","\n","$L38","\n","$L39","\n","$L3a","\n","$L3b","\n","$L3c","\n","$L3d","\n","$L3e","\n","$L3f","\n","$L40","\n","$L41","\n","$L42","\n","$L43","\n","$L44","\n","$L45","\n","$L46","\n","$L47","\n","$L48","\n","$L49"]
