2c:["$","li","TTPs",{"className":"group inline-block max-w-full group-hover:cursor-pointer underline-offset-4","children":["$","$L5",null,{"href":"/tags/ttps","className":"relative inline-flex max-w-full items-center whitespace-nowrap underline decoration-dashed transition-colors group-hover:-top-0.5 group-hover:text-accent focus-visible:p-1 text-sm underline-offset-4","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"mr-1 inline-block shrink-0 opacity-80 sm:mr-1.5 size-3.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M5 9l14 0"}],["$","path",null,{"d":"M5 15l14 0"}],["$","path",null,{"d":"M11 4l-4 16"}],["$","path",null,{"d":"M17 4l-4 16"}]]}],["$","span",null,{"children":"TTPs"}]]}]}]
