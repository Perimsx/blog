42:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L4a",null,{"text":"# 使用 Docker 快速部署 MISP\ngit clone https://github.com/MISP/misp-docker.git\ncd misp-docker\ncp template.env .env\n# 编辑 .env 文件设置密码和域名\ndocker compose up -d\n\n# 使用 PyMISP 库与 MISP API 交互\npip install pymisp\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-bash","children":"# 使用 Docker 快速部署 MISP\ngit clone https://github.com/MISP/misp-docker.git\ncd misp-docker\ncp template.env .env\n# 编辑 .env 文件设置密码和域名\ndocker compose up -d\n\n# 使用 PyMISP 库与 MISP API 交互\npip install pymisp\n"}]}]]}]
43:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L4a",null,{"text":"from pymisp import PyMISP\n\n# 连接 MISP 实例\nmisp = PyMISP(\"https://your-misp-instance.local\", \"YOUR_API_KEY\", ssl=False)\n\n# 搜索包含特定 IP 的事件\nresults = misp.search(value=\"198.51.100.1\", type_attribute=\"ip-dst\")\nfor event in results:\n    print(f\"Event: {event['Event']['info']}\")\n    print(f\"  Date: {event['Event']['date']}\")\n    print(f\"  Threat Level: {event['Event']['threat_level_id']}\")\n\n# 创建新的威胁情报事件\nevent = misp.new_event(\n    distribution=0,\n    threat_level_id=2,\n    analysis=1,\n    info=\"Suspicious C2 Activity - Campaign 2025-Q4\"\n)\n\n# 向事件添加 IOC 属性\nmisp.add_attribute(event, type=\"ip-dst\", value=\"198.51.100.50\", comment=\"C2 Server\")\nmisp.add_attribute(event, type=\"domain\", value=\"evil-c2.example.com\", comment=\"C2 Domain\")\nmisp.add_attribute(event, type=\"sha256\", value=\"a]\" * 32, comment=\"Malware Sample Hash\")\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-python","children":"from pymisp import PyMISP\n\n# 连接 MISP 实例\nmisp = PyMISP(\"https://your-misp-instance.local\", \"YOUR_API_KEY\", ssl=False)\n\n# 搜索包含特定 IP 的事件\nresults = misp.search(value=\"198.51.100.1\", type_attribute=\"ip-dst\")\nfor event in results:\n    print(f\"Event: {event['Event']['info']}\")\n    print(f\"  Date: {event['Event']['date']}\")\n    print(f\"  Threat Level: {event['Event']['threat_level_id']}\")\n\n# 创建新的威胁情报事件\nevent = misp.new_event(\n    distribution=0,\n    threat_level_id=2,\n    analysis=1,\n    info=\"Suspicious C2 Activity - Campaign 2025-Q4\"\n)\n\n# 向事件添加 IOC 属性\nmisp.add_attribute(event, type=\"ip-dst\", value=\"198.51.100.50\", comment=\"C2 Server\")\nmisp.add_attribute(event, type=\"domain\", value=\"evil-c2.example.com\", comment=\"C2 Domain\")\nmisp.add_attribute(event, type=\"sha256\", value=\"a]\" * 32, comment=\"Malware Sample Hash\")\n"}]}]]}]
