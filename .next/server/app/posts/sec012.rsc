31:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L4a",null,{"text":"# 使用 VirusTotal API 查询文件哈希\ncurl -s \"https://www.virustotal.com/api/v3/files/44d88612fea8a8f36de82e1278abb02f\" \\\n  -H \"x-apikey: YOUR_VT_API_KEY\" | jq '.data.attributes.last_analysis_stats'\n\n# 使用 VirusTotal API 查询域名信誉\ncurl -s \"https://www.virustotal.com/api/v3/domains/malicious-example.com\" \\\n  -H \"x-apikey: YOUR_VT_API_KEY\" | jq '.data.attributes.last_analysis_stats'\n\n# 使用 AbuseIPDB API 查询 IP 信誉\ncurl -s \"https://api.abuseipdb.com/api/v2/check\" \\\n  -H \"Key: YOUR_ABUSEIPDB_KEY\" \\\n  -H \"Accept: application/json\" \\\n  -d \"ipAddress=198.51.100.1&maxAgeInDays=90\" | jq '.data'\n\n# 使用 Shodan 查询 IP 相关信息\ncurl -s \"https://api.shodan.io/shodan/host/198.51.100.1?key=YOUR_SHODAN_KEY\" | jq '{ip: .ip_str, org: .org, ports: .ports}'\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-bash","children":"# 使用 VirusTotal API 查询文件哈希\ncurl -s \"https://www.virustotal.com/api/v3/files/44d88612fea8a8f36de82e1278abb02f\" \\\n  -H \"x-apikey: YOUR_VT_API_KEY\" | jq '.data.attributes.last_analysis_stats'\n\n# 使用 VirusTotal API 查询域名信誉\ncurl -s \"https://www.virustotal.com/api/v3/domains/malicious-example.com\" \\\n  -H \"x-apikey: YOUR_VT_API_KEY\" | jq '.data.attributes.last_analysis_stats'\n\n# 使用 AbuseIPDB API 查询 IP 信誉\ncurl -s \"https://api.abuseipdb.com/api/v2/check\" \\\n  -H \"Key: YOUR_ABUSEIPDB_KEY\" \\\n  -H \"Accept: application/json\" \\\n  -d \"ipAddress=198.51.100.1&maxAgeInDays=90\" | jq '.data'\n\n# 使用 Shodan 查询 IP 相关信息\ncurl -s \"https://api.shodan.io/shodan/host/198.51.100.1?key=YOUR_SHODAN_KEY\" | jq '{ip: .ip_str, org: .org, ports: .ports}'\n"}]}]]}]
4b:T579,import requests
import json
import time

VT_API_KEY = "YOUR_VT_API_KEY"
VT_BASE_URL = "https://www.virustotal.com/api/v3"

def query_vt_hash(file_hash):
    """查询 VirusTotal 文件哈希信誉"""
    headers = {"x-apikey": VT_API_KEY}
    url = f"{VT_BASE_URL}/files/{file_hash}"
    response = requests.get(url, headers=headers)
    if response.status_code == 200:
        data = response.json()
        stats = data["data"]["attributes"]["last_analysis_stats"]
        name = data["data"]["attributes"].get("meaningful_name", "Unknown")
        return {
            "hash": file_hash,
            "name": name,
            "malicious": stats.get("malicious", 0),
            "undetected": stats.get("undetected", 0),
            "total_engines": sum(stats.values())
        }
    return {"hash": file_hash, "error": f"HTTP {response.status_code}"}

def batch_query_iocs(hash_list):
    """批量查询 IOC 哈希列表"""
    results = []
    for h in hash_list:
        result = query_vt_hash(h)
        results.append(result)
        print(f"[*] {h[:16]}... => malicious: {result.get('malicious', 'N/A')}")
        time.sleep(15)  # 免费 API 限速: 4次/分钟
    return results

# 示例用法
suspicious_hashes = [
    "44d88612fea8a8f36de82e1278abb02f",  # EICAR 测试文件
    "e3b0c44298fc1c149afbf4c8996fb924",  # 空文件 SHA-256
]

results = batch_query_iocs(suspicious_hashes)
4c:T579,import requests
import json
import time

VT_API_KEY = "YOUR_VT_API_KEY"
VT_BASE_URL = "https://www.virustotal.com/api/v3"

def query_vt_hash(file_hash):
    """查询 VirusTotal 文件哈希信誉"""
    headers = {"x-apikey": VT_API_KEY}
    url = f"{VT_BASE_URL}/files/{file_hash}"
    response = requests.get(url, headers=headers)
    if response.status_code == 200:
        data = response.json()
        stats = data["data"]["attributes"]["last_analysis_stats"]
        name = data["data"]["attributes"].get("meaningful_name", "Unknown")
        return {
            "hash": file_hash,
            "name": name,
            "malicious": stats.get("malicious", 0),
            "undetected": stats.get("undetected", 0),
            "total_engines": sum(stats.values())
        }
    return {"hash": file_hash, "error": f"HTTP {response.status_code}"}

def batch_query_iocs(hash_list):
    """批量查询 IOC 哈希列表"""
    results = []
    for h in hash_list:
        result = query_vt_hash(h)
        results.append(result)
        print(f"[*] {h[:16]}... => malicious: {result.get('malicious', 'N/A')}")
        time.sleep(15)  # 免费 API 限速: 4次/分钟
    return results

# 示例用法
suspicious_hashes = [
    "44d88612fea8a8f36de82e1278abb02f",  # EICAR 测试文件
    "e3b0c44298fc1c149afbf4c8996fb924",  # 空文件 SHA-256
]

results = batch_query_iocs(suspicious_hashes)
