3b:["$","ul",null,{"children":["\n",["$","li",null,{"children":"标注组织当前的检测覆盖范围"}],"\n",["$","li",null,{"children":"映射特定威胁组织的 TTPs"}],"\n",["$","li",null,{"children":"对比不同攻击组织的技术偏好"}],"\n",["$","li",null,{"children":"评估安全控制的有效性"}],"\n"]}]
