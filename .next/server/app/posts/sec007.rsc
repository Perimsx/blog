2e:["$","div",null,{"className":"flex flex-col sm:flex-row justify-between gap-6","children":[["$","$L5",null,{"href":"/posts/sec008","className":"flex gap-2 hover:opacity-75 items-start","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M15 6l-6 6l6 6"}]]}],["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"上一篇"}],["$","div",null,{"className":"text-accent/85","children":"VPN技术与搭建实战"}]]}]]}],["$","$L5",null,{"href":"/posts/sec005","className":"flex gap-2 hover:opacity-75 items-start justify-end text-right ml-auto","children":[["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"下一篇"}],["$","div",null,{"className":"text-accent/85","children":"网络安全合规要求解读"}]]}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M9 6l6 6l-6 6"}]]}]]}]]}]
25:[["$","blockquote",null,{"children":["\n",["$","p",null,{"children":"阅读提示\n适合对象：计划部署 Snort、Suricata 或做流量检测规则编写的读者。\n阅读前提：了解 TCP/IP、抓包和基本 Linux 服务部署。\n核心收获：理解 IDS/IPS 部署模式、规则设计与误报调优方法。\n说明：规则语法与性能参数可能因版本不同而变化。"}],"\n"]}],"\n",["$","p",null,{"children":"在网络安全防御体系中，防火墙负责对流量进行访问控制，而入侵检测系统（IDS）和入侵防御系统（IPS）则承担着更深层次的职责——检测并识别网络中的恶意行为和攻击流量。本文将详细介绍 IDS/IPS 的核心概念，并以 Snort 和 Suricata 两款主流开源工具为例，讲解部署方法、规则编写和告警分析实战。"}],"\n",["$","h2",null,{"id":"ids-与-ips-的概念区别","children":["IDS 与 IPS 的概念区别",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#ids-与-ips-的概念区别","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","h3",null,{"id":"入侵检测系统ids","children":["入侵检测系统（IDS）",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#入侵检测系统ids","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":["IDS（Intrusion Detection System）以旁路（被动）模式部署，通过镜像端口或 TAP 设备获取网络流量的副本进行分析。当检测到可疑活动时，IDS 会产生告警通知管理员，但",["$","strong",null,{"children":"不会主动阻断流量"}],"。优点是不影响网络性能，缺点是响应滞后。"]}],"\n",["$","h3",null,{"id":"入侵防御系统ips","children":["入侵防御系统（IPS）",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#入侵防御系统ips","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":["IPS（Intrusion Prevention System）以串联（主动）模式部署在网络路径中，所有流量都必须经过 IPS。当检测到攻击流量时，IPS 能够",["$","strong",null,{"children":"实时阻断"}],"恶意数据包。防护更主动，但如果规则配置不当可能造成误杀合法流量。"]}],"\n",["$","h3",null,{"id":"部署模式选择","children":["部署模式选择",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#部署模式选择","children":["$","span",null,{"children":"#"}]}]]}],"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n",["$","table",null,{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th",null,{"children":"模式"}],["$","th",null,{"children":"部署位置"}],["$","th",null,{"children":"特点"}],["$","th",null,{"children":"适用场景"}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"children":[["$","td",null,{"children":"IDS（旁路）"}],["$","td",null,{"children":"交换机镜像端口"}],["$","td",null,{"children":"不影响流量，只告警"}],["$","td",null,{"children":"监控分析、合规审计"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"IPS（串联）"}],["$","td",null,{"children":"网络出入口串联"}],["$","td",null,{"children":"实时阻断，有延迟影响"}],["$","td",null,{"children":"边界主动防御"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"混合模式"}],["$","td",null,{"children":"同时部署"}],["$","td",null,{"children":"兼顾监控和防御"}],["$","td",null,{"children":"大型网络环境"}]]}]]}]]}],"\n",["$","h2",null,{"id":"snort-安装与基本配置","children":["Snort 安装与基本配置",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#snort-安装与基本配置","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"Snort 是由 Martin Roesch 于 1998 年创建的老牌开源 IDS/IPS，目前由 Cisco Talos 团队维护。它支持实时流量分析、协议解析和内容匹配。"}],"\n",["$","h3",null,{"id":"安装-snort-3","children":["安装 Snort 3",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#安装-snort-3","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L30","\n",["$","h3",null,{"id":"snortlua-核心配置","children":["snort.lua 核心配置",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#snortlua-核心配置","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"Snort 3 使用 Lua 格式的配置文件（Snort 2 使用 snort.conf）："}],"\n","$L31","\n",["$","h3",null,{"id":"启动-snort","children":["启动 Snort",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#启动-snort","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L32","\n",["$","h2",null,{"id":"snort-规则语法详解","children":["Snort 规则语法详解",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#snort-规则语法详解","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":["Snort 规则是其核心，每条规则由",["$","strong",null,{"children":"规则头"}],"和",["$","strong",null,{"children":"规则选项"}],"两部分组成。"]}],"\n",["$","h3",null,{"id":"规则基本结构","children":["规则基本结构",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#规则基本结构","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L33","\n",["$","h3",null,{"id":"规则示例详解","children":["规则示例详解",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#规则示例详解","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L34","\n",["$","h3",null,{"id":"关键规则选项说明","children":["关键规则选项说明",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#关键规则选项说明","children":["$","span",null,{"children":"#"}]}]]}],"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n",["$","table",null,{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th",null,{"children":"选项"}],["$","th",null,{"children":"作用"}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"children":[["$","td",null,{"children":["$","code",null,{"children":"msg"}]}],["$","td",null,{"children":"告警消息文本"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"$L35"}],"$L36"]}],"$L37","$L38","$L39","$L3a","$L3b","$L3c","$L3d","$L3e","$L3f","$L40","$L41"]}]]}],"\n","$L42","\n","$L43","\n","$L44","\n","$L45","\n","$L46","\n","$L47","\n","$L48","\n","$L49","\n","$L4a","\n","$L4b","\n","$L4c","\n","$L4d","\n","$L4e","\n","$L4f","\n","$L50","\n","$L51","\n","$L52","\n","$L53","\n","$L54"]
