58:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5f",null,{"text":"$60"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-bash","children":"$61"}]}]]}]
5a:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5f",null,{"text":"# 使用 Nessus REST API 启动扫描\n\nNESSUS_URL=\"https://localhost:8834\"\nAPI_KEY=\"accessKey=YOUR_ACCESS_KEY;secretKey=YOUR_SECRET_KEY\"\n\n# 列出扫描任务\ncurl -sk -H \"X-ApiKeys: ${API_KEY}\" \\\n    \"${NESSUS_URL}/scans\" | python3 -m json.tool\n\n# 启动指定扫描\nSCAN_ID=5\ncurl -sk -X POST -H \"X-ApiKeys: ${API_KEY}\" \\\n    \"${NESSUS_URL}/scans/${SCAN_ID}/launch\"\n\n# 导出扫描报告（PDF格式）\ncurl -sk -X POST -H \"X-ApiKeys: ${API_KEY}\" \\\n    -H \"Content-Type: application/json\" \\\n    -d '{\"format\":\"pdf\"}' \\\n    \"${NESSUS_URL}/scans/${SCAN_ID}/export\"\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-bash","children":"# 使用 Nessus REST API 启动扫描\n\nNESSUS_URL=\"https://localhost:8834\"\nAPI_KEY=\"accessKey=YOUR_ACCESS_KEY;secretKey=YOUR_SECRET_KEY\"\n\n# 列出扫描任务\ncurl -sk -H \"X-ApiKeys: ${API_KEY}\" \\\n    \"${NESSUS_URL}/scans\" | python3 -m json.tool\n\n# 启动指定扫描\nSCAN_ID=5\ncurl -sk -X POST -H \"X-ApiKeys: ${API_KEY}\" \\\n    \"${NESSUS_URL}/scans/${SCAN_ID}/launch\"\n\n# 导出扫描报告（PDF格式）\ncurl -sk -X POST -H \"X-ApiKeys: ${API_KEY}\" \\\n    -H \"Content-Type: application/json\" \\\n    -d '{\"format\":\"pdf\"}' \\\n    \"${NESSUS_URL}/scans/${SCAN_ID}/export\"\n"}]}]]}]
