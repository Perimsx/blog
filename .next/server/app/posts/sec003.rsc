2e:["$","div",null,{"className":"flex flex-col sm:flex-row justify-between gap-6","children":[["$","$L5",null,{"href":"/posts/sec004","className":"flex gap-2 hover:opacity-75 items-start","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M15 6l-6 6l6 6"}]]}],["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"上一篇"}],["$","div",null,{"className":"text-accent/85","children":"密码学基础与应用"}]]}]]}],["$","$L5",null,{"href":"/posts/sec002","className":"flex gap-2 hover:opacity-75 items-start justify-end text-right ml-auto","children":[["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"block text-sm text-foreground/70","children":"下一篇"}],["$","div",null,{"className":"text-accent/85","children":"TCPIP协议安全分析"}]]}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","className":"inline-block flex-shrink-0 mt-0.5","children":[["$","path",null,{"d":"M0 0h24v24H0z","stroke":"none"}],["$","path",null,{"d":"M9 6l6 6l-6 6"}]]}]]}]]}]
25:[["$","blockquote",null,{"children":["\n",["$","p",null,{"children":"阅读提示\n适合对象：想建立攻击面认知的安全初学者、开发者与测试人员。\n阅读前提：了解 HTTP、浏览器与基础网络通信概念。\n核心收获：快速区分常见攻击原理、触发条件与对应防护思路。"}],"\n"]}],"\n",["$","p",null,{"children":"网络攻击技术日新月异，但万变不离其宗——多数攻击都是围绕几类经典手法演化而来。理解这些核心攻击手法的原理、分类和利用方式，不仅是渗透测试人员的必备技能，也是开发人员和运维工程师构建安全系统的基础。本文将深入解析五种最常见且影响最广的网络攻击手法：DDoS、中间人攻击、SQL 注入、XSS 和 CSRF，并给出对应的防御方案。"}],"\n",["$","h2",null,{"id":"ddos-攻击","children":["DDoS 攻击",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#ddos-攻击","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"DDoS（Distributed Denial of Service，分布式拒绝服务）攻击通过控制大量计算机（僵尸网络）向目标系统发送海量请求，耗尽其带宽、计算或连接资源，导致正常用户无法访问服务。"}],"\n",["$","h3",null,{"id":"攻击类型","children":["攻击类型",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#攻击类型","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":["$","strong",null,{"children":"SYN Flood（传输层）"}]}],"\n",["$","p",null,{"children":"利用 TCP 三次握手的缺陷，发送大量 SYN 请求但不完成握手，使服务器维护大量半连接状态直至资源耗尽。"}],"\n","$L30","\n",["$","p",null,{"children":["$","strong",null,{"children":"UDP Flood（传输层）"}]}],"\n",["$","p",null,{"children":"向目标发送大量 UDP 数据包，由于 UDP 是无连接协议，目标需要消耗资源检查每个端口上是否有监听的应用程序，当端口不可达时还需回复 ICMP 不可达消息。"}],"\n",["$","p",null,{"children":["$","strong",null,{"children":"HTTP Flood（应用层）"}]}],"\n",["$","p",null,{"children":"模拟大量合法的 HTTP 请求，消耗 Web 服务器的计算资源。由于请求看起来与正常流量相似，这类攻击更难以检测和过滤。"}],"\n","$L31","\n",["$","h3",null,{"id":"ddos-防御策略","children":["DDoS 防御策略",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#ddos-防御策略","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L32","\n",["$","p",null,{"children":"此外，还应考虑使用 CDN 服务（如 Cloudflare）分散流量、部署专业的 DDoS 防护设备（如 Anti-DDoS 清洗中心）、以及与 ISP 合作进行上游流量过滤。"}],"\n",["$","h2",null,{"id":"中间人攻击mitm","children":["中间人攻击（MITM）",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#中间人攻击mitm","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"中间人攻击（Man-in-the-Middle）是指攻击者秘密地拦截并可能篡改两方之间的通信，而双方都以为自己在直接与对方通信。"}],"\n",["$","h3",null,{"id":"攻击原理","children":["攻击原理",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#攻击原理","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"中间人攻击的典型场景是：攻击者同时欺骗通信双方，使自己成为通信链路中的\"透明\"中间节点。所有流量先经过攻击者，攻击者可以查看、记录甚至修改流量内容后再转发。"}],"\n",["$","h3",null,{"id":"ettercap-实战示例","children":["Ettercap 实战示例",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#ettercap-实战示例","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"Ettercap 是一款强大的中间人攻击工具，支持 ARP 欺骗、DNS 欺骗和内容过滤等功能。"}],"\n","$L33","\n",["$","h3",null,{"id":"使用-mitmproxy-拦截-https-流量","children":["使用 mitmproxy 拦截 HTTPS 流量",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#使用-mitmproxy-拦截-https-流量","children":["$","span",null,{"children":"#"}]}]]}],"\n","$L34","\n",["$","h3",null,{"id":"mitm-防御措施","children":["MITM 防御措施",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#mitm-防御措施","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"全站 HTTPS"}],"：加密传输内容，防止明文嗅探"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"HSTS（HTTP Strict Transport Security）"}],"：强制浏览器使用 HTTPS"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"证书锁定（Certificate Pinning）"}],"：在客户端固定服务器证书，防止伪造证书"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"VPN"}],"：在不可信的网络环境中使用 VPN 加密所有流量"]}],"\n"]}],"\n",["$","h2",null,{"id":"sql-注入攻击","children":["SQL 注入攻击",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#sql-注入攻击","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"SQL 注入（SQL Injection）是最经典也最危险的 Web 漏洞之一。当应用程序将用户输入直接拼接到 SQL 语句中执行时，攻击者可以注入恶意 SQL 代码来操纵数据库。"}],"\n",["$","h3",null,{"id":"攻击原理-1","children":["攻击原理",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#攻击原理-1","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"假设有一个登录功能，后端代码如下："}],"\n","$L35","\n",["$","p",null,{"children":["当攻击者在用户名字段输入 ",["$","code",null,{"children":"admin' --"}]," 时，SQL 语句变为："]}],"\n","$L36","\n",["$","p",null,{"children":[["$","code",null,{"children":"--"}]," 是 SQL 注释符，后面的密码验证被注释掉了，攻击者无需密码即可登录 admin 账户。"]}],"\n",["$","h3",null,{"id":"sql-注入分类与示例","children":["SQL 注入分类与示例",["$","a",null,{"className":"anchor-link","aria-label":"Permalink","href":"#sql-注入分类与示例","children":["$","span",null,{"children":"#"}]}]]}],"\n",["$","p",null,{"children":"$L37"}],"\n","$L38","\n","$L39","\n","$L3a","\n","$L3b","\n","$L3c","\n","$L3d","\n","$L3e","\n","$L3f","\n","$L40","\n","$L41","\n","$L42","\n","$L43","\n","$L44","\n","$L45","\n","$L46","\n","$L47","\n","$L48","\n","$L49","\n","$L4a","\n","$L4b","\n","$L4c","\n","$L4d","\n","$L4e","\n","$L4f","\n","$L50","\n","$L51","\n","$L52","\n","$L53","\n","$L54","\n","$L55","\n","$L56","\n","$L57","\n","$L58","\n","$L59","\n","$L5a","\n","$L5b","\n","$L5c","\n","$L5d"]
